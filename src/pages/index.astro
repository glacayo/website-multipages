---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/layout/TopBar.astro';
import Header from '../components/layout/Header.astro';
import HeroSlider from '../components/sections/HeroSlider.astro';
import CTABar from '../components/sections/CTABar.astro';
import DirectoryBadges from '../components/sections/DirectoryBadges.astro';
import Welcome from '../components/sections/Welcome.astro';
import Services from '../components/sections/Services.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Gallery from '../components/sections/Gallery.astro';
import About from '../components/sections/About.astro';
import MissionVision from '../components/sections/MissionVision.astro';
import ContactForm from '../components/sections/ContactForm.astro';
import FAQ from '../components/sections/FAQ.astro';
import CoveredAreas from '../components/sections/CoveredAreas.astro';
import content from '../data/content.json';

const { seo } = content;
---

<BaseLayout 
  title={seo.home_title}
  description={seo.home_description}
>
  <TopBar />
  <Header />
  <HeroSlider />
  <CTABar />
  <Welcome />
  <Services />
  <Testimonials />
  <Gallery />
  <About />
  <MissionVision />
  <ContactForm />
  <FAQ />
  <CoveredAreas />
  <DirectoryBadges />
</BaseLayout>
