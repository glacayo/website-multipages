---
/**
 * Dynamic service landing routes.
 * Paths come from business.json.services_offered; content merges
 * services.json + landings.json with a generic fallback.
 */
import LandingLayout from '../../layouts/LandingLayout.astro';
import { getBusiness, getSite } from '../../data/loaders';
import { publishesServiceDetail } from '../../utils/routes';

export function getStaticPaths() {
  const site = getSite();
  if (!publishesServiceDetail(site)) {
    return [];
  }

  const business = getBusiness();
  return business.services_offered.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/services');
}
---

<LandingLayout slug={slug} />
