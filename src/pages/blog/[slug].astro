---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import ResponsiveImage from '../../components/ui/ResponsiveImage.astro';
import CTABar from '../../components/sections/CTABar.astro';
import {
  getBlogPost,
  getPublishedBlogPosts,
  getSite,
} from '../../data/loaders';

export function getStaticPaths() {
  const site = getSite();
  if (!site.features.enable_blog) {
    return [];
  }

  return getPublishedBlogPosts().map((post) => ({
    params: { slug: post.slug },
  }));
}

const site = getSite();

if (!site.features.enable_blog) {
  return Astro.redirect('/');
}

const { slug } = Astro.params;
const post = slug ? getBlogPost(slug) : undefined;

if (!post || !post.published) {
  return Astro.redirect('/blog');
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Pass meta_title or headline only — buildSeo()/composeTitle appends site name
// when no separator is already present (S4.1–S4.3).
const pageTitle = post.meta_title || post.headline;
---

<BaseLayout
  title={pageTitle}
  description={post.description || post.excerpt.slice(0, 160)}
  path={`/blog/${post.slug}`}
  pageType="post"
  post={post}
  type="article"
  image={post.image}
>
  <section class="relative overflow-hidden bg-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-primary to-accent/60"></div>
    <div class="container-site relative z-10 flex min-h-[320px] flex-col items-center justify-center py-16 text-center text-white md:min-h-[400px]">
      <h1 class="font-heading mb-4 max-w-3xl text-2xl font-bold md:text-4xl lg:text-5xl">
        {post.headline}
      </h1>
      <Breadcrumb
        items={[
          { label: 'Home', href: '/' },
          { label: 'Blog', href: '/blog' },
          { label: 'Article' },
        ]}
        class="[&_a]:text-white/70 [&_a:hover]:text-accent [&_span]:text-accent [&_.text-muted]:text-white/50 [&_.text-dark]:text-accent"
      />
    </div>
  </section>

  <article class="bg-white py-10 md:py-16">
    <div class="container-site">
      <div class="mx-auto max-w-3xl">
        <div class="mb-8 overflow-hidden rounded-2xl shadow-lg">
          <ResponsiveImage
            src={post.image}
            alt={post.image_alt || post.headline}
            width={1200}
            height={675}
            lcp
            class="h-auto w-full object-cover"
          />
        </div>

        <div class="mb-10 flex flex-wrap items-center gap-4 border-b border-border pb-8 text-sm text-muted">
          <span>{formatDate(post.date)}</span>
          <span class="text-border">|</span>
          <span>{post.author}</span>
          <span class="text-border">|</span>
          <span>{post.category}</span>
          <span class="text-border">|</span>
          <span>{post.reading_time}</span>
        </div>

        <div class="blog-content">
          <Fragment set:html={post.content} />
        </div>
      </div>
    </div>
  </article>

  <CTABar />
</BaseLayout>

<style is:global>
  .blog-content p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--color-muted);
    font-size: 1.0625rem;
  }

  .blog-content h2 {
    font-family: var(--font-heading, system-ui, sans-serif);
    font-weight: 700;
    font-size: 1.75rem;
    color: var(--color-dark);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .blog-content h3 {
    font-family: var(--font-heading, system-ui, sans-serif);
    font-weight: 600;
    font-size: 1.35rem;
    color: var(--color-dark);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }

  .blog-content ul,
  .blog-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--color-muted);
  }

  .blog-content ul {
    list-style-type: disc;
  }

  .blog-content ol {
    list-style-type: decimal;
  }

  .blog-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
    font-size: 1.0625rem;
  }

  .blog-content strong {
    color: var(--color-dark);
    font-weight: 600;
  }

  .blog-content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-content a:hover {
    color: var(--color-primary);
  }
</style>
