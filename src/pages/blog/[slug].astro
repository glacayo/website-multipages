---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/layout/TopBar.astro';
import Header from '../../components/layout/Header.astro';
import CTABar from '../../components/sections/CTABar.astro';
import blogsData from '../../data/blogs.json';
import content from '../../data/content.json';

export function getStaticPaths() {
  const posts = blogsData.posts || [];
  return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const posts = blogsData.posts || [];
const post = posts.find((p: any) => p.slug === slug);

if (!post) return Astro.redirect('/blog');

const { company_name } = content;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title={`${post.headline} | ${company_name}`}
  description={post.description || post.excerpt?.slice(0, 160)}
>
  <TopBar />
  <Header />

  <!-- ===== Header ===== -->
  <section class="relative -mt-[5.5rem] md:-mt-[6.5rem]">
    <div class="relative h-[45vh] min-h-[350px] md:min-h-[450px] overflow-hidden bg-dark">
      <div class="absolute inset-0 bg-gradient-to-br from-dark/90 via-primary/40 to-accent/60"></div>
      <div class="relative z-10 container-site h-full flex flex-col items-center justify-center text-center text-white">
        <h1 class="font-heading text-2xl md:text-4xl lg:text-5xl font-bold mb-4">{post.headline}</h1>
        <nav class="flex items-center justify-center gap-2 text-sm text-white/70" aria-label="Breadcrumb">
          <a href="/" class="hover:text-accent transition-colors">Home</a>
          <i class="fa-solid fa-chevron-right text-[10px]"></i>
          <a href="/blog" class="hover:text-accent transition-colors">Blog</a>
          <i class="fa-solid fa-chevron-right text-[10px]"></i>
          <span class="text-accent">Article</span>
        </nav>
      </div>
    </div>
  </section>

  <!-- ===== Article Body ===== -->
  <article class="py-10 md:py-16 bg-white">
    <div class="container-site">
      <div class="max-w-3xl mx-auto">

        <!-- Feature Image -->
        <div class="rounded-2xl overflow-hidden shadow-lg mb-8 shimmer-bg">
          <img
            src={"/images/blog/" + (post.image_filename || "5.jpg")}
            alt={post.headline}
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>

        <!-- Meta Bar -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 mb-10 pb-8 border-b border-gray-100">
          <span class="flex items-center gap-1.5">
            <i class="fa-solid fa-calendar text-accent"></i>
            {formatDate(post.date)}
          </span>
          <span class="text-gray-300">|</span>
          <span class="flex items-center gap-1.5">
            <i class="fa-solid fa-user text-accent"></i>
            {post.author}
          </span>
          <span class="text-gray-300">|</span>
          <span class="flex items-center gap-1.5">
            <i class="fa-solid fa-tag text-accent"></i>
            {post.category}
          </span>
          <span class="text-gray-300">|</span>
          <span class="flex items-center gap-1.5">
            <i class="fa-solid fa-clock text-accent"></i>
            {post.reading_time}
          </span>
        </div>

        <!-- Content -->
        <div class="blog-content">
          <Fragment set:html={post.content} />
        </div>

      </div>
    </div>
  </article>

  <CTABar />
</BaseLayout>

<style is:global>
  .blog-content p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: #374151;
    font-size: 1.0625rem;
  }

  .blog-content h2 {
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.75rem;
    color: #1f2937;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .blog-content h3 {
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.35rem;
    color: #1f2937;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }

  .blog-content ul,
  .blog-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: #374151;
  }

  .blog-content ul {
    list-style-type: disc;
  }

  .blog-content ol {
    list-style-type: decimal;
  }

  .blog-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
    font-size: 1.0625rem;
  }

  .blog-content strong {
    color: #1f2937;
    font-weight: 600;
  }

  .blog-content a {
    color: #962e20;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-content a:hover {
    color: #003060;
  }
</style>
