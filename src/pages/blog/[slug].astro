---
/**
 * Blog Post Page - src/pages/blog/[slug].astro
 * Displays a single blog post with full content
 */
import { getBlogPosts, getSiteContent } from '../../data/loaders';
import BlogLayout from '../../layouts/BlogLayout.astro';
import SectionHeading from '../../components/shared/SectionHeading.astro';
import CTASection from '../../components/shared/CTASection.astro';

export function getStaticPaths() {
  const data = getBlogPosts();
  return data.posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// Format date
const formatDate = (dateStr: string): string => {
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
  } catch {
    return dateStr;
  }
};

// SEO props
const pageTitle = post.meta_title || post.headline;
const pageDescription = post.description;
const pagePath = `/blog/${post.slug}`;
const imageUrl = `/images/${post.image_filename}`;

const content = getSiteContent();
const companyName = content.company_name;
---

<BlogLayout
  title={pageTitle}
  description={pageDescription}
  path={pagePath}
  image={imageUrl}
  post={post}
>
  <!-- Article Hero -->
  <section class="bg-primary py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category Badge -->
      <div class="mb-4">
        <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">
          {post.category}
        </span>
      </div>

      <!-- Headline -->
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
        {post.headline}
      </h1>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-200">
        <time datetime={post.date}>
          {formatDate(post.date)}
        </time>
        <span class="text-white/50" aria-hidden="true">|</span>
        <span>{post.reading_time}</span>
        <span class="text-white/50" aria-hidden="true">|</span>
        <span>By {post.author}</span>
      </div>
    </div>
  </section>

  <!-- Featured Image -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10">
    <img
      src={imageUrl}
      alt={post.headline}
      class="w-full h-auto md:h-[400px] object-cover rounded-xl shadow-lg"
      loading="eager"
    />
  </div>

  <!-- Article Content -->
  <article class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Blog body content rendered as HTML -->
      <div class="prose prose-lg max-w-none" set:html={post.content} />

      <!-- Tags / Meta -->
      <div class="mt-12 pt-8 border-t border-gray-200">
        <div class="flex flex-wrap items-center gap-4">
          <span class="text-sm font-semibold text-dark">Category:</span>
          <span class="inline-block bg-primary/10 text-primary text-xs font-semibold px-3 py-1 rounded-full">
            {post.category}
          </span>
        </div>
      </div>
    </div>
  </article>

  <!-- Author Bio -->
  <section class="py-8 bg-gray-50 border-t border-gray-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-xl">
          {post.author.charAt(0)}
        </div>
        <div>
          <p class="font-semibold text-dark">{post.author}</p>
          <p class="text-sm text-text-secondary">{companyName}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    headline="Ready to Start Your Project?"
    buttonText="Get Free Estimate"
  />
</BlogLayout>
