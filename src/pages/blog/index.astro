---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Button from '../../components/ui/Button.astro';
import ResponsiveImage from '../../components/ui/ResponsiveImage.astro';
import CTABar from '../../components/sections/CTABar.astro';
import {
  getBusiness,
  getPublishedBlogPosts,
  getSite,
} from '../../data/loaders';

const business = getBusiness();
const site = getSite();

if (!site.features.enable_blog) {
  return Astro.redirect('/');
}

const posts = getPublishedBlogPosts().sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
const postsPerPage = 10;
const totalPages = Math.max(1, Math.ceil(posts.length / postsPerPage));
const currentPage = 1;
const pagePosts = posts.slice(0, postsPerPage);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`Blog${site.seo.title_separator}${business.name}`}
  description={`News and tips from ${business.name}.`}
  path="/blog"
  pageType="blog"
>
  <section class="relative overflow-hidden bg-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-primary to-accent/70"></div>
    <div class="container-site relative z-10 flex min-h-[280px] flex-col items-center justify-center py-16 text-center text-white md:min-h-[340px]">
      <h1 class="font-heading mb-4 text-3xl font-bold md:text-5xl" data-reveal>Our Blog</h1>
      <Breadcrumb
        items={[{ label: 'Home', href: '/' }, { label: 'Blog' }]}
        class="[&_a]:text-white/70 [&_a:hover]:text-accent [&_span]:text-accent [&_.text-muted]:text-white/50 [&_.text-dark]:text-accent"
      />
    </div>
  </section>

  <section class="bg-surface py-16 md:py-24">
    <div class="container-site">
      {
        pagePosts.length === 0 ? (
          <p class="text-center text-muted">No published posts yet.</p>
        ) : (
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            {pagePosts.map((post) => (
              <article class="overflow-hidden rounded-2xl border border-border bg-white shadow-sm">
                <a href={`/blog/${post.slug}`} class="block">
                  <ResponsiveImage
                    src={post.image}
                    alt={post.image_alt || post.headline}
                    width={800}
                    height={480}
                    class="h-52 w-full object-cover"
                  />
                </a>
                <div class="p-6">
                  <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-accent">
                    {post.category} · {formatDate(post.date)}
                  </p>
                  <h2 class="font-heading mb-3 text-xl font-bold text-dark">
                    <a href={`/blog/${post.slug}`} class="hover:text-primary">
                      {post.headline}
                    </a>
                  </h2>
                  <p class="mb-4 text-sm leading-relaxed text-muted">{post.excerpt}</p>
                  <Button href={`/blog/${post.slug}`} variant="ghost" size="sm">
                    Read more
                  </Button>
                </div>
              </article>
            ))}
          </div>
        )
      }

      {
        totalPages > 1 && (
          <nav class="mt-12 flex items-center justify-center gap-3" aria-label="Blog pagination">
            <span class="text-sm text-muted">
              Page {currentPage} of {totalPages}
            </span>
            <Button href="/blog/2" variant="outline" size="sm">
              Next
            </Button>
          </nav>
        )
      }
    </div>
  </section>

  <CTABar />
</BaseLayout>
