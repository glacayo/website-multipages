---
/**
 * Landing Page - src/pages/landing/[slug].astro
 * Displays a service landing page with hero and 3 content sections
 */
import { getLandingPages } from '../../data/loaders';
import LandingLayout from '../../layouts/LandingLayout.astro';
import SectionHeading from '../../components/shared/SectionHeading.astro';
import CTASection from '../../components/shared/CTASection.astro';

export function getStaticPaths() {
  const data = getLandingPages();
  return data.landing_pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;

// SEO props
const pageTitle = page.name;
const pageDescription = page.hero.paragraph.substring(0, 160);
const pagePath = `/landing/${page.slug}`;
const heroImage = `/images/${page.hero.image}`;
---

<LandingLayout
  title={pageTitle}
  description={pageDescription}
  path={pagePath}
  image={heroImage}
>
  <!-- Hero Section -->
  <section class="relative min-h-[500px] md:min-h-[600px] flex items-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <img
        src={heroImage}
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
      />
      <!-- Overlay -->
      <div class="absolute inset-0 bg-gradient-to-r from-dark/80 to-dark/40"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
      <div class="max-w-4xl">
        <!-- Headline -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          {page.hero.headline}
        </h1>

        <!-- Paragraph -->
        <p class="text-xl text-gray-200 mb-8 leading-relaxed">
          {page.hero.paragraph}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 bg-accent text-white px-8 py-4 rounded-lg text-lg font-bold hover:bg-opacity-90 transition-all duration-200 cursor-pointer shadow-lg hover:shadow-xl"
          >
            Get Free Estimate
          </a>

          <a
            href="tel:+17575551234"
            class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white hover:text-primary transition-all duration-200 cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  {page.sections.map((section, index) => {
    const isEven = index % 2 === 0;
    const sectionImage = `/images/${section.image}`;

    return (
      <section class={`py-16 md:py-20 ${isEven ? 'bg-white' : 'bg-gray-50'}`}>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${!isEven ? 'lg:grid-flow-dense' : ''}`}>
            <!-- Text Content -->
            <div class={!isEven ? 'lg:col-start-2' : ''}>
              <SectionHeading
                title={section.headline}
                align={isEven ? 'left' : 'right'}
              />

              {/* Three paragraphs */}
              {section.paragraphs.map((paragraph) => (
                <p class="text-text-secondary text-lg leading-relaxed mb-4">
                  {paragraph}
                </p>
              ))}

              <!-- CTA -->
              <div class="mt-8">
                <a
                  href="/contact"
                  class="inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-lg text-lg font-bold hover:bg-primary/90 transition-all duration-200 cursor-pointer shadow-lg hover:shadow-xl"
                >
                  Get Free Estimate
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>

            <!-- Image -->
            <div class={!isEven ? 'lg:col-start-1 lg:row-start-1' : ''}>
              <img
                src={sectionImage}
                alt={section.headline}
                class="w-full h-auto rounded-xl shadow-lg"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </section>
    );
  })}

  <!-- Final CTA Section -->
  <CTASection
    headline="Ready to Get Started?"
    buttonText="Call Now"
  />
</LandingLayout>
