---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABar from '../components/sections/CTABar.astro';
import Services from '../components/sections/Services/Services.astro';
import { getBusiness, getSite, getServices } from '../data/loaders';

const business = getBusiness();
const site = getSite();
const servicesData = getServices();
---

<BaseLayout
  title={`Services${site.seo.title_separator}${business.name}`}
  description={servicesData.section_subtitle || `Explore ${business.type_of_services}`}
  path="/services"
  pageType="services"
>
  <!-- ===== Page Header ===== -->
  <section class="relative">
    <div class="relative h-[40vh] min-h-[300px] md:min-h-[380px] overflow-hidden bg-dark">
      <div class="absolute inset-0 bg-gradient-to-br from-dark via-primary to-accent/70"></div>
      <div class="relative z-10 container-site h-full flex flex-col items-center justify-center text-center text-white">
        <h1 class="font-heading text-3xl md:text-5xl lg:text-6xl font-bold mb-4" data-reveal>
          {servicesData.section_title}
        </h1>
        <nav
          class="flex items-center justify-center gap-2 text-sm text-white/70"
          aria-label="Breadcrumb"
          data-reveal
          data-reveal-delay="0.1"
        >
          <a href="/" class="hover:text-accent transition-colors">Home</a>
          <span aria-hidden="true">/</span>
          <span class="text-accent">Services</span>
        </nav>
      </div>
    </div>
  </section>

  <Services />

  <CTABar />
</BaseLayout>
