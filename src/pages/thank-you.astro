---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import CTABar from '../components/sections/CTABar.astro';
import { getBusiness, getSite } from '../data/loaders';

const business = getBusiness();
const site = getSite();
const primaryPhone = business.phones[0] ?? '';
---

<BaseLayout
  title={`Thank You${site.seo.title_separator}${business.name}`}
  description="Your message has been received. We will get back to you shortly."
  path="/thank-you"
  pageType="other"
  noindex={true}
>
  <section class="relative overflow-hidden bg-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-primary to-accent/60"></div>
    <div class="container-site relative z-10 flex min-h-[70vh] items-center py-20 text-center text-white">
      <div class="mx-auto max-w-lg">
        <div
          class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-accent/20 text-3xl font-bold text-accent"
          aria-hidden="true"
        >
          ✓
        </div>
        <h1 class="font-heading mb-4 text-3xl font-bold md:text-5xl">Thank you!</h1>
        <p class="mb-8 text-base leading-relaxed text-white/75 md:text-lg">
          Your message has been received. A member of the {business.name} team will get back
          to you within one business day.
        </p>
        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
          <Button href="/" variant="primary" size="md">Back to home</Button>
          {
            primaryPhone && (
              <Button
                href={`tel:${primaryPhone.replace(/\D/g, '')}`}
                variant="outline"
                size="md"
                class="border-white/30 text-white hover:bg-white hover:text-primary"
              >
                {primaryPhone}
              </Button>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <CTABar />
</BaseLayout>
