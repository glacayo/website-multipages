---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { getBusiness, getContactPath, getSite } from '../data/loaders';

const business = getBusiness();
const site = getSite();
const contactHref = getContactPath();
---

<BaseLayout
  title={`404 - Page Not Found${site.seo.title_separator}${business.name}`}
  description="The page you are looking for does not exist."
  path="/404"
  pageType="other"
  noindex={true}
>
  <section class="relative overflow-hidden bg-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-primary to-accent/60"></div>
    <div class="container-site relative z-10 flex min-h-[70vh] items-center py-20 text-center text-white">
      <div class="mx-auto max-w-lg">
        <span class="font-heading mb-4 block text-8xl font-extrabold leading-none text-white/10 md:text-9xl">
          404
        </span>
        <h1 class="font-heading mb-4 text-3xl font-bold md:text-5xl">Page not found</h1>
        <p class="mb-8 text-base text-white/70 md:text-lg">
          The page you are looking for might have been removed, renamed, or is temporarily
          unavailable.
        </p>
        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
          <Button href="/" variant="primary" size="md">Back to home</Button>
          <Button
            href={contactHref}
            variant="outline"
            size="md"
            class="border-white/30 text-white hover:bg-white hover:text-primary"
          >
            Contact us
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
