---
/**
 * Contact Page - contact.astro
 * Contact form, phone, address, and service area info
 */
import { getSiteContent } from '../data/loaders';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/shared/SectionHeading.astro';
import CTASection from '../components/shared/CTASection.astro';

const content = getSiteContent();

const pageTitle = `Contact Us | ${content.company_name}`;
const pageDescription = `Get in touch with ${content.company_name} for free estimates on masonry, hardscape, and concrete projects in ${content.company_cover_area}.`;
const pagePath = '/contact';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path={pagePath}
>
  <!-- Page Hero -->
  <section class="bg-primary py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Contact Us
      </h1>
      <p class="text-xl text-gray-200 max-w-4xl mx-auto">
        Ready to start your project? Reach out today for a free estimate
      </p>
    </div>
  </section>

  <!-- Contact Info Grid -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <!-- Phone -->
        <div class="text-center p-8 bg-gray-50 rounded-xl">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">Call Us</h3>
          {
            content.company_phone.map((phone) => (
              <a
                href={`tel:${phone.replace(/[^0-9]/g, '')}`}
                class="text-primary font-semibold hover:text-accent transition-colors duration-200 block"
              >
                {phone}
              </a>
            ))
          }
        </div>

        <!-- Email -->
        <div class="text-center p-8 bg-gray-50 rounded-xl">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">Email Us</h3>
          {
            content.company_email.map((email) => (
              <a
                href={`mailto:${email}`}
                class="text-primary font-semibold hover:text-accent transition-colors duration-200 block"
              >
                {email}
              </a>
            ))
          }
        </div>

        <!-- Address -->
        <div class="text-center p-8 bg-gray-50 rounded-xl">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">Visit Us</h3>
          <p class="text-text-secondary">{content.company_address}</p>
        </div>
      </div>

      <!-- Schedule & Payment -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <div class="bg-gray-50 rounded-xl p-8">
          <SectionHeading
            title="Business Hours"
            align="left"
          />
          <div class="space-y-2">
            {content.company_schedule.map((schedule) => (
              <p class="text-text-secondary text-lg flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {schedule}
              </p>
            ))}
          </div>
        </div>

        <div class="bg-gray-50 rounded-xl p-8">
          <SectionHeading
            title="Service Area"
            align="left"
          />
          <p class="text-text-secondary text-lg mb-4">
            Proudly serving {content.company_type_services.toLowerCase()} clients across:
          </p>
          <div class="flex flex-wrap gap-2">
            {content.company_cover_area.split(',').map((city: string) => (
              <span class="bg-primary/10 text-primary px-4 py-2 rounded-full text-sm font-medium">
                {city.trim()}
              </span>
            ))}
          </div>
          <div class="mt-6 space-y-2">
            <p class="text-text-secondary text-lg flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {content.company_years_experience}
            </p>
            <p class="text-text-secondary text-lg flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {content.company_estimate}
            </p>
            <p class="text-text-secondary text-lg flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {content.company_payment_method}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    headline="Ready to Start Your Project?"
    buttonText="Call Now"
  />
</BaseLayout>
