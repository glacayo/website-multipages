---
/**
 * Dark footer: multi-column brand + services + contact on dark gradient.
 */
import { getBusiness, getNavigation, getSite } from '../../../../data/loaders';
import MapPin from '@lucide/astro/icons/map-pin';
import Phone from '@lucide/astro/icons/phone';
import Mail from '@lucide/astro/icons/mail';
import Clock from '@lucide/astro/icons/clock';
import Check from '@lucide/astro/icons/check';

const site = getSite();
const business = getBusiness();
const navigation = getNavigation();
const year = new Date().getFullYear();
const primaryPhone = business.phones[0];
const primaryEmail = business.emails[0];
const telHref = primaryPhone ? `tel:${primaryPhone.replace(/\D/g, '')}` : undefined;
const primaryHours = business.hours[0];
---

<footer
  data-footer-variant="dark"
  class="bg-gradient-to-b from-dark via-primary-dark to-primary-dark text-white"
>
  <div class="container-site py-16 md:py-20">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-12">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="mb-5 inline-block">
          <img
            src={site.logo.src}
            alt={site.logo.alt || business.name}
            width={site.logo.width || 200}
            height={site.logo.height || 50}
            class="h-14 w-auto object-contain brightness-200 contrast-125 md:h-16"
          />
        </a>
        <p class="mb-4 text-sm leading-relaxed text-white/60">{business.tagline}</p>
        <p class="inline-flex items-center gap-2 text-sm text-white/70">
          <Check class="size-4 text-accent" aria-hidden="true" />
          {business.license}
        </p>
      </div>

      {
        navigation.footer.map((column) => (
          <div>
            <h4 class="font-heading mb-5 text-lg font-bold text-white">{column.title}</h4>
            <ul class="space-y-2.5">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-white/60 transition-colors hover:text-accent"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div>
        <h4 class="font-heading mb-5 text-lg font-bold text-white">Contact</h4>
        <ul class="space-y-4 text-sm text-white/60">
          <li class="flex items-start gap-3">
            <MapPin class="mt-0.5 size-4 shrink-0 text-accent" aria-hidden="true" />
            <span>{business.address.full}</span>
          </li>
          {
            primaryPhone && telHref && (
              <li>
                <a href={telHref} class="inline-flex items-center gap-3 hover:text-accent">
                  <Phone class="size-4 text-accent" aria-hidden="true" />
                  {primaryPhone}
                </a>
              </li>
            )
          }
          {
            primaryEmail && (
              <li>
                <a
                  href={`mailto:${primaryEmail}`}
                  class="inline-flex items-center gap-3 hover:text-accent"
                >
                  <Mail class="size-4 text-accent" aria-hidden="true" />
                  {primaryEmail}
                </a>
              </li>
            )
          }
          {
            primaryHours && (
              <li class="flex items-start gap-3">
                <Clock class="mt-0.5 size-4 shrink-0 text-accent" aria-hidden="true" />
                <span>
                  {primaryHours.days}: {primaryHours.time}
                </span>
              </li>
            )
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-site flex flex-col items-center justify-between gap-3 py-5 text-sm text-white/50 sm:flex-row">
      <p>
        &copy; {year} {business.name}. All rights reserved.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        {
          navigation.legal.map((link) => (
            <a href={link.href} class="transition-colors hover:text-accent">
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
