---
/**
 * Default footer: brand blurb + nav columns + contact on light surface.
 */
import { getBusiness, getNavigation, getSite } from '../../../../data/loaders';
import MapPin from '@lucide/astro/icons/map-pin';
import Phone from '@lucide/astro/icons/phone';
import Mail from '@lucide/astro/icons/mail';

const site = getSite();
const business = getBusiness();
const navigation = getNavigation();
const year = new Date().getFullYear();
const primaryPhone = business.phones[0];
const primaryEmail = business.emails[0];
const telHref = primaryPhone ? `tel:${primaryPhone.replace(/\D/g, '')}` : undefined;
---

<footer data-footer-variant="default" class="border-t border-border bg-white text-dark">
  <div class="container-site py-14 md:py-16">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <img
            src={site.logo.src}
            alt={site.logo.alt || business.name}
            width={site.logo.width || 200}
            height={site.logo.height || 50}
            class="h-12 w-auto object-contain"
          />
        </a>
        <p class="text-sm leading-relaxed text-muted">{business.tagline}</p>
      </div>

      {
        navigation.footer.map((column) => (
          <div>
            <h4 class="font-heading mb-4 text-base font-bold text-dark">{column.title}</h4>
            <ul class="space-y-2.5">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-muted transition-colors hover:text-accent"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div>
        <h4 class="font-heading mb-4 text-base font-bold text-dark">Contact</h4>
        <ul class="space-y-3 text-sm text-muted">
          <li class="flex items-start gap-2">
            <MapPin class="mt-0.5 size-4 shrink-0 text-accent" aria-hidden="true" />
            <span>{business.address.full}</span>
          </li>
          {
            primaryPhone && telHref && (
              <li>
                <a href={telHref} class="inline-flex items-center gap-2 hover:text-accent">
                  <Phone class="size-4 text-accent" aria-hidden="true" />
                  {primaryPhone}
                </a>
              </li>
            )
          }
          {
            primaryEmail && (
              <li>
                <a
                  href={`mailto:${primaryEmail}`}
                  class="inline-flex items-center gap-2 hover:text-accent"
                >
                  <Mail class="size-4 text-accent" aria-hidden="true" />
                  {primaryEmail}
                </a>
              </li>
            )
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-border">
    <div class="container-site flex flex-col items-center justify-between gap-3 py-5 text-sm text-muted sm:flex-row">
      <p>
        &copy; {year} {business.name}. All rights reserved.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        {
          navigation.legal.map((link) => (
            <a href={link.href} class="hover:text-accent transition-colors">
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
