---
import content from '../../data/content.json';

const { company_phone, mobile_cta } = content;
---

<div
  x-data="{ visible: false }"
  x-init="window.addEventListener('scroll', () => { visible = window.scrollY > 300 })"
  x-show="visible"
  x-transition:enter="transition ease-out duration-400"
  x-transition:enter-start="opacity-0 translate-y-4"
  x-transition:enter-end="opacity-100 translate-y-0"
  x-transition:leave="transition ease-in duration-300"
  x-transition:leave-start="opacity-100 translate-y-0"
  x-transition:leave-end="opacity-0 translate-y-4"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 lg:hidden"
>
  <a
    href={`tel:${company_phone[0].replace(/\D/g, '')}`}
    class="flex items-center justify-center gap-2 px-8 py-3.5 bg-accent text-white font-semibold text-sm rounded-full shadow-2xl shadow-accent/30 hover:bg-accent/90 active:bg-accent/80 transition-colors animate-float whitespace-nowrap"
  >
    <i class="fa-solid fa-phone"></i>
    {mobile_cta}
  </a>
</div>

<style is:global>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>
