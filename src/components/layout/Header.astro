---
import content from '../../data/content.json';
import { getNavigation } from '../../utils/navigation';
import NavMenu from './NavMenu.astro';

const { company_name, company_estimate } = content;
const navItems = getNavigation();
---

<header 
  x-data="{ 
    scrolled: false, 
    menuOpen: false,
    init() {
      this.scrolled = window.scrollY > 50;
      window.addEventListener('scroll', () => {
        this.scrolled = window.scrollY > 50;
      });
    }
  }"
  :class="scrolled ? 'bg-white shadow-lg' : 'bg-transparent'"
  class="sticky top-0 z-40 transition-all duration-300"
>
  <div class="container-site relative">
    <!-- Logo absolute: grande flotando sobre el hero, compacto al scrollear -->
    <a 
      href="/" 
      :class="scrolled ? 'h-12 md:h-16 top-1/2 -translate-y-1/2' : 'h-[4.6rem] md:h-[6.6rem] top-1'"
      class="absolute left-5 sm:left-8 lg:left-12 xl:left-16 z-50 group transition-all duration-500 ease-out"
    >
      <div class="h-full relative">
        <img 
          src="/logo.png" 
          alt={company_name} 
          class="h-full w-auto object-contain transition-transform duration-300 group-hover:scale-105"
        />
        <div class="shine-logo-sweep absolute inset-0 z-10"></div>
      </div>
    </a>

    <div class="grid grid-cols-[1fr_auto] items-center h-16 md:h-20 pl-[5rem] md:pl-[8rem]">
      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center justify-center gap-1"
        :class="scrolled ? 'text-dark' : 'text-white/90'">
        <NavMenu items={navItems} />
      </nav>
      
      <!-- CTA + Mobile Menu Button (right column) -->
      <div class="grid grid-flow-col items-center gap-3 justify-self-end">
        <a 
          href="/contact-us"
          class="hidden lg:inline-flex items-center gap-2 px-6 py-2.5 bg-accent text-white text-sm font-semibold rounded-md hover:bg-accent/90 hover:shadow-lg hover:shadow-accent/20 hover:-translate-y-0.5 transition-all duration-300 shine-effect"
        >
          <i class="fa-solid fa-calendar-check"></i>
          {company_estimate}
        </a>
        
        <button 
          @click="menuOpen = !menuOpen"
          :class="scrolled || menuOpen ? 'text-dark' : 'text-white'"
          class="lg:hidden w-10 h-10 inline-flex items-center justify-center rounded-md hover:bg-white/10 transition-colors duration-300"
          aria-label="Toggle menu"
        >
          <i 
            :class="menuOpen ? 'fa-solid fa-xmark' : 'fa-solid fa-bars'"
            class="text-xl transition-transform duration-300"
          ></i>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Mobile Menu Overlay -->
  <div 
    x-show="menuOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 -translate-y-4"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-4"
    class="lg:hidden absolute top-full left-0 right-0 bg-white shadow-xl border-t border-gray-100"
    @click.away="menuOpen = false"
  >
    <div class="container-site py-6">
      <nav class="grid gap-2" @click="if ($event.target.closest('a')) menuOpen = false">
        <NavMenu items={navItems} mobile={true} />
        
        <div class="pt-4 mt-2 border-t border-gray-100">
          <a 
            href="/contact-us"
            @click="menuOpen = false"
            class="flex items-center justify-center gap-2 w-full px-6 py-3 bg-accent text-white font-semibold rounded-md hover:bg-accent/90 transition-colors duration-300 shine-effect"
          >
            <i class="fa-solid fa-calendar-check"></i>
            {company_estimate}
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>
