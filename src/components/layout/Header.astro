---
/**
 * Header dispatcher — selects a visual variant from site.json.header_variant.
 * Unknown values fall back to `default` without failing the build (spec §2.3).
 */
import { getSite } from '../../data/loaders';
import {
  headerVariants,
  HEADER_DEFAULT_VARIANT,
  type HeaderVariantKey,
} from './Header/variants';

const site = getSite();
const requested = (site.header_variant ?? HEADER_DEFAULT_VARIANT) as HeaderVariantKey;
const Variant =
  headerVariants[requested] ?? headerVariants[HEADER_DEFAULT_VARIANT];
---

<Variant />
