---
/**
 * Footer dispatcher — selects a visual variant from site.json.footer_variant.
 * Unknown values fall back to `default` without failing the build (spec §2.3).
 */
import { getSite } from '../../data/loaders';
import {
  footerVariants,
  FOOTER_DEFAULT_VARIANT,
  type FooterVariantKey,
} from './Footer/variants';

const site = getSite();
const requested = (site.footer_variant ?? FOOTER_DEFAULT_VARIANT) as FooterVariantKey;
const Variant =
  footerVariants[requested] ?? footerVariants[FOOTER_DEFAULT_VARIANT];
---

<Variant />
