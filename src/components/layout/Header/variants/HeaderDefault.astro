---
/**
 * Default header: sticky solid bar, logo left, nav center, CTA right.
 */
import { getBusiness, getContactPath, getSite } from '../../../../data/loaders';
import NavMenu from '../../NavMenu.astro';
import Button from '../../../ui/Button.astro';
import Menu from '@lucide/astro/icons/menu';
import X from '@lucide/astro/icons/x';

const site = getSite();
const business = getBusiness();
const contactHref = getContactPath();
---

<header
  data-header-variant="default"
  class="sticky top-0 z-40 border-b border-border/60 bg-white/95 text-dark shadow-sm backdrop-blur-md"
  x-data="{ menuOpen: false }"
  x-on:keydown.escape.window="menuOpen = false"
>
  <div class="container-site">
    <div class="flex h-16 items-center justify-between gap-4 md:h-20">
      <a href="/" class="relative z-50 shrink-0 group">
        <img
          src={site.logo.src}
          alt={site.logo.alt || business.name}
          width={site.logo.width || 200}
          height={site.logo.height || 50}
          class="h-10 w-auto object-contain transition-transform duration-300 group-hover:scale-105 md:h-12"
        />
      </a>

      <div class="hidden flex-1 justify-center lg:flex">
        <NavMenu />
      </div>

      <div class="flex items-center gap-3">
        <Button href={contactHref} size="sm" class="hidden lg:inline-flex">
          {business.free_estimate}
        </Button>

        <button
          type="button"
          class="inline-flex size-10 items-center justify-center rounded-md text-dark hover:bg-surface lg:hidden"
          x-on:click="menuOpen = !menuOpen"
          :aria-expanded="menuOpen.toString()"
          aria-controls="mobile-nav-default"
          aria-label="Toggle menu"
        >
          <Menu class="size-6" x-show="!menuOpen" aria-hidden="true" />
          <X class="size-6" x-show="menuOpen" x-cloak aria-hidden="true" style="display: none;" />
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-nav-default"
    class="border-t border-border bg-white shadow-xl lg:hidden"
    x-show="menuOpen"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    style="display: none;"
  >
    <div class="container-site py-4" x-on:click="if ($event.target.closest('a')) menuOpen = false">
      <NavMenu mobile />
      <div class="mt-4 border-t border-border pt-4">
        <Button href={contactHref} class="w-full">
          {business.free_estimate}
        </Button>
      </div>
    </div>
  </div>
</header>
