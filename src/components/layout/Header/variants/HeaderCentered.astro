---
/**
 * Centered header: logo centered on top row, nav + CTA below.
 */
import { getBusiness, getSite } from '../../../../data/loaders';
import NavMenu from '../../NavMenu.astro';
import Button from '../../../ui/Button.astro';
import Menu from '@lucide/astro/icons/menu';
import X from '@lucide/astro/icons/x';

const site = getSite();
const business = getBusiness();
---

<header
  data-header-variant="centered"
  class="sticky top-0 z-40 border-b border-border/60 bg-white text-dark shadow-sm"
  x-data="{ menuOpen: false }"
  x-on:keydown.escape.window="menuOpen = false"
>
  <div class="container-site">
    <div class="flex h-16 items-center justify-between md:h-20 lg:justify-center">
      <div class="w-10 lg:hidden" aria-hidden="true"></div>

      <a href="/" class="group">
        <img
          src={site.logo.src}
          alt={site.logo.alt || business.name}
          width={site.logo.width || 200}
          height={site.logo.height || 50}
          class="mx-auto h-11 w-auto object-contain transition-transform duration-300 group-hover:scale-105 md:h-14"
        />
      </a>

      <button
        type="button"
        class="inline-flex size-10 items-center justify-center rounded-md text-dark hover:bg-surface lg:hidden"
        x-on:click="menuOpen = !menuOpen"
        :aria-expanded="menuOpen.toString()"
        aria-controls="mobile-nav-centered"
        aria-label="Toggle menu"
      >
        <Menu class="size-6" x-show="!menuOpen" aria-hidden="true" />
        <X class="size-6" x-show="menuOpen" x-cloak aria-hidden="true" style="display: none;" />
      </button>
    </div>

    <div class="hidden items-center justify-center gap-6 border-t border-border/50 py-3 lg:flex">
      <NavMenu />
      <Button href="/contact-us" size="sm">
        {business.free_estimate}
      </Button>
    </div>
  </div>

  <div
    id="mobile-nav-centered"
    class="border-t border-border bg-white shadow-xl lg:hidden"
    x-show="menuOpen"
    x-cloak
    x-transition
    style="display: none;"
  >
    <div class="container-site py-4" x-on:click="if ($event.target.closest('a')) menuOpen = false">
      <NavMenu mobile />
      <div class="mt-4 border-t border-border pt-4">
        <Button href="/contact-us" class="w-full">
          {business.free_estimate}
        </Button>
      </div>
    </div>
  </div>
</header>
