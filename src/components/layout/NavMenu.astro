---
/**
 * Desktop / mobile navigation from navigation.json.
 * Dropdowns and expanders use Alpine.js.
 */
import { getNavigation } from '../../data/loaders';
import type { NavItem } from '../../data/types';
import ChevronDown from '@lucide/astro/icons/chevron-down';

interface Props {
  /** When true, renders stacked mobile styles. */
  mobile?: boolean;
  /** Override nav items (defaults to navigation.header). */
  items?: NavItem[];
  class?: string;
}

const navigation = getNavigation();
const {
  mobile = false,
  items = navigation.header,
  class: className = '',
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
  const normalized = href.replace(/\/$/, '') || '/';
  if (normalized === '/') return currentPath === '/';
  return currentPath === normalized || currentPath.startsWith(`${normalized}/`);
}

function desktopLinkClass(href: string): string {
  const base =
    'relative px-3 py-2 text-sm font-medium transition-colors duration-300 rounded-md text-inherit hover:text-accent inline-flex items-center gap-1';
  return isActive(href) ? `${base} !text-accent` : base;
}

function mobileLinkClass(href: string): string {
  const base =
    'block px-4 py-3 text-base font-medium rounded-md transition-colors duration-200 text-dark hover:bg-gray-50 hover:text-accent';
  return isActive(href) ? `${base} bg-accent/10 text-accent` : base;
}
---

<nav
  class:list={[
    mobile ? 'grid gap-1' : 'flex items-center gap-0.5',
    className,
  ]}
  data-navmenu={mobile ? 'mobile' : 'desktop'}
  aria-label={mobile ? 'Mobile navigation' : 'Primary navigation'}
>
  {
    items.map((item) => {
      const children = item.children ?? [];
      if (children.length === 0) {
        return (
          <a
            href={item.href}
            class={mobile ? mobileLinkClass(item.href) : desktopLinkClass(item.href)}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        );
      }

      if (mobile) {
        return (
          <div x-data="{ open: false }">
            <button
              type="button"
              class:list={[
                'flex w-full items-center justify-between px-4 py-3 text-base font-medium rounded-md text-dark hover:bg-gray-50 hover:text-accent',
                isActive(item.href) ? 'text-accent' : '',
              ]}
              x-on:click="open = !open"
              x-bind:aria-expanded="open"
              aria-haspopup="true"
            >
              <span>{item.label}</span>
              <ChevronDown
                class="size-3.5 transition-transform duration-200"
                x-bind:class="open ? 'rotate-180' : ''"
                aria-hidden="true"
              />
            </button>
            <div
              x-show="open"
              x-cloak
              x-collapse
              class="grid gap-0.5 pl-4 pb-2"
              style="display: none;"
            >
              <a href={item.href} class={mobileLinkClass(item.href)}>
                All {item.label}
              </a>
              {children.map((child) => (
                <a href={child.href} class={mobileLinkClass(child.href)}>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        );
      }

      return (
        <div
          class="relative"
          x-data="{ open: false }"
          x-on:mouseenter="open = true"
          x-on:mouseleave="open = false"
        >
          <button
            type="button"
            class={desktopLinkClass(item.href)}
            x-on:click="open = !open"
            x-bind:aria-expanded="open"
            aria-haspopup="true"
          >
            <span>{item.label}</span>
            <ChevronDown
              class="size-3.5 transition-transform duration-200"
              x-bind:class="open ? 'rotate-180' : ''"
              aria-hidden="true"
            />
          </button>
          <div
            x-show="open"
            x-cloak
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 translate-y-1"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-1"
            x-on:click.outside="open = false"
            class="absolute top-full left-0 z-50 mt-1 min-w-[12.5rem] rounded-lg border border-border bg-white py-2 shadow-xl"
            style="display: none;"
          >
            <a
              href={item.href}
              class:list={[
                'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-accent',
                isActive(item.href) ? 'text-accent font-semibold' : '',
              ]}
            >
              All {item.label}
            </a>
            {children.map((child) => (
              <a
                href={child.href}
                class:list={[
                  'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-accent',
                  isActive(child.href) ? 'text-accent font-semibold' : '',
                ]}
              >
                {child.label}
              </a>
            ))}
          </div>
        </div>
      );
    })
  }
</nav>
