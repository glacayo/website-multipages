---
/**
 * Variant `cards` — responsive card grid of quotes.
 */
import type { TestimonialsData } from '../../../../data/types';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import Card from '../../../ui/Card.astro';
import Star from '@lucide/astro/icons/star';

interface Props {
  data: TestimonialsData;
}

const { data } = Astro.props;

function initials(name: string): string {
  return name
    .split(/\s+/)
    .map((part) => part[0] ?? '')
    .join('')
    .slice(0, 2)
    .toUpperCase();
}
---

<SectionWrapper background="muted" id="testimonials">
  <SectionHeader title={data.section_title} subtitle={data.section_subtitle} />

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      data.testimonials.map((t, i) => (
        <div data-reveal data-reveal-delay={String(i * 0.08)}>
          <Card as="article" variant="hover-lift" class="p-6 border border-border h-full flex flex-col">
            <div class="flex gap-0.5 text-amber-400 mb-4" aria-label={`${t.stars} out of 5 stars`}>
              {Array.from({ length: 5 }).map((_, si) => (
                <Star
                  class:list={[
                    'w-4 h-4',
                    si < t.stars ? 'fill-amber-400' : 'text-border fill-none',
                  ]}
                />
              ))}
            </div>
            <blockquote class="text-dark/80 text-sm md:text-base leading-relaxed mb-5 flex-1">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border mt-auto">
              <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center text-xs font-bold flex-shrink-0">
                {t.avatar ?? initials(t.name)}
              </div>
              <div class="min-w-0">
                <p class="font-semibold text-dark text-sm">{t.name}</p>
                <p class="text-muted text-xs">
                  {t.location}
                  {t.service ? ` · ${t.service}` : ''}
                </p>
              </div>
            </div>
          </Card>
        </div>
      ))
    }
  </div>
</SectionWrapper>
