---
import content from '../../data/content.json';

const { company_phone, company_payment_method, company_estimate, company_cover_area, company_schedule, faqs, section_headings } = content;
const { faq: faqHeadings } = section_headings;

const processedFaqs = faqs.map(faq => ({
  q: faq.q,
  a: faq.a
    .replace('{cover_area}', company_cover_area)
    .replace('{estimate}', company_estimate)
    .replace('{phone}', company_phone[0])
    .replace('{payment}', company_payment_method)
    .replace('{schedule}', company_schedule[0]),
}));
---

<section class="py-16 md:py-24 bg-white">
  <div class="container-site">
    <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16" data-reveal>
      <span class="inline-flex items-center gap-2 text-accent font-semibold text-sm uppercase tracking-[0.2em] mb-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        {faqHeadings.badge}
      </span>
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-dark mb-4">
        {faqHeadings.headline_line1}<span class="text-primary">{faqHeadings.headline_line2}</span>
      </h2>
      <p class="text-gray-500 text-base md:text-lg">
        {faqHeadings.subtitle}
      </p>
    </div>

    <div class="max-w-3xl mx-auto space-y-3" x-data="{ active: null }">
      {processedFaqs.map((faq, i) => (
        <div
          data-reveal
          data-reveal-delay={String(i * 0.08)}
          class="border border-gray-200 rounded-xl overflow-hidden transition-all duration-300"
          :class={`active === ${i} ? 'border-accent/30 shadow-sm' : ''`}
        >
          <button
            @click={`active = active === ${i} ? null : ${i}`}
            class="w-full flex items-center justify-between p-5 md:p-6 text-left hover:bg-gray-50 transition-colors duration-200"
          >
            <span class="font-semibold text-dark text-sm md:text-base pr-4">{faq.q}</span>
            <i
              class="fa-solid fa-chevron-down text-accent text-sm transition-transform duration-300 flex-shrink-0"
              :class={`active === ${i} ? 'rotate-180' : ''`}
            ></i>
          </button>
          <div
            x-show={`active === ${i}`}
            x-collapse
            class="px-5 md:px-6 pb-5 text-gray-600 text-sm md:text-base leading-relaxed"
          >
            {faq.a}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
