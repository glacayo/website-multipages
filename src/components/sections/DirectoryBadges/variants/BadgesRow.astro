---
/**
 * Variant `badges` — horizontal autoplay Swiper row of directory badges.
 */
import 'swiper/css';
import 'swiper/css/autoplay';
import type { DirectoriesData } from '../../../../data/types';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import ExternalLink from '@lucide/astro/icons/external-link';

interface Props {
  data: DirectoriesData;
}

const { data } = Astro.props;
---

<SectionWrapper background="dark" id="directories" class="overflow-hidden">
  <SectionHeader
    title={data.section_title}
    subtitle={data.section_subtitle}
    titleClass="!text-white"
    subtitleClass="!text-white/70"
  />

  <div class="directory-badges-swiper swiper" data-directory-badges-row data-reveal>
    <div class="swiper-wrapper !items-center">
      {
        data.directories.map((dir) => (
          <a
            href={dir.url}
            target="_blank"
            rel="noopener noreferrer"
            class="swiper-slide h-auto flex justify-center"
          >
            <div class="group flex flex-col items-center gap-3 p-4 transition-all duration-300 grayscale hover:grayscale-0">
              <div class="w-20 h-20 md:w-24 md:h-24 rounded-full bg-white/5 border border-white/10 flex items-center justify-center overflow-hidden group-hover:bg-white/10 group-hover:border-accent/50 transition-all duration-300">
                <span class="font-heading font-bold text-xl md:text-2xl text-gray-400 group-hover:text-accent transition-colors duration-300">
                  {dir.initials ?? dir.name.slice(0, 2).toUpperCase()}
                </span>
              </div>
              <span class="text-sm md:text-base font-semibold text-gray-400 group-hover:text-white transition-colors duration-300 text-center inline-flex items-center gap-1">
                {dir.name}
                <ExternalLink class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</SectionWrapper>

<style>
  .grayscale {
    filter: grayscale(100%);
  }
  .grayscale:hover {
    filter: grayscale(0%);
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Autoplay } from 'swiper/modules';

  const root = document.querySelector('[data-directory-badges-row]');
  if (root) {
    new Swiper(root as HTMLElement, {
      modules: [Autoplay],
      slidesPerView: 2,
      spaceBetween: 16,
      loop: true,
      speed: 600,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      breakpoints: {
        640: { slidesPerView: 3, spaceBetween: 24 },
        768: { slidesPerView: 4, spaceBetween: 24 },
        1024: { slidesPerView: 5, spaceBetween: 32 },
      },
    });
  }
</script>
