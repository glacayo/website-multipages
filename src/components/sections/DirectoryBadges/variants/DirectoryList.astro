---
/**
 * Variant `list` — stacked list of directory links with initials.
 */
import type { DirectoriesData } from '../../../../data/types';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import ExternalLink from '@lucide/astro/icons/external-link';
import ArrowUpRight from '@lucide/astro/icons/arrow-up-right';

interface Props {
  data: DirectoriesData;
}

const { data } = Astro.props;
---

<SectionWrapper background="muted" id="directories">
  <SectionHeader title={data.section_title} subtitle={data.section_subtitle} />

  <ul class="max-w-xl mx-auto space-y-3">
    {
      data.directories.map((dir, i) => (
        <li data-reveal data-reveal-delay={String(i * 0.05)}>
          <a
            href={dir.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 p-4 rounded-xl bg-light border border-border hover:border-accent/40 hover:shadow-sm transition-all"
          >
            <span class="w-11 h-11 rounded-lg bg-primary/10 text-primary font-heading font-bold text-sm flex items-center justify-center flex-shrink-0">
              {dir.initials ?? dir.name.slice(0, 2).toUpperCase()}
            </span>
            <span class="flex-1 font-semibold text-dark text-sm md:text-base group-hover:text-primary transition-colors">
              {dir.name}
            </span>
            <ArrowUpRight class="w-4 h-4 text-muted group-hover:text-accent transition-colors" />
            <span class="sr-only">
              (opens in new tab)
              <ExternalLink class="w-3 h-3" />
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</SectionWrapper>
