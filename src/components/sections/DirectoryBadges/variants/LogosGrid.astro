---
/**
 * Variant `logos` — static grid of circular logo/initial badges.
 */
import type { DirectoriesData } from '../../../../data/types';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import ExternalLink from '@lucide/astro/icons/external-link';

interface Props {
  data: DirectoriesData;
}

const { data } = Astro.props;
---

<SectionWrapper background="dark" id="directories">
  <SectionHeader
    title={data.section_title}
    subtitle={data.section_subtitle}
    titleClass="!text-white"
    subtitleClass="!text-white/70"
  />

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 md:gap-8 max-w-4xl mx-auto">
    {
      data.directories.map((dir, i) => (
        <a
          href={dir.url}
          target="_blank"
          rel="noopener noreferrer"
          data-reveal
          data-reveal-delay={String(i * 0.06)}
          class="group flex flex-col items-center gap-3 p-4 rounded-xl hover:bg-white/5 transition-colors"
        >
          <div class="w-20 h-20 md:w-24 md:h-24 rounded-full bg-white/5 border border-white/10 flex items-center justify-center group-hover:border-accent/50 group-hover:bg-white/10 transition-all duration-300">
            <span class="font-heading font-bold text-xl md:text-2xl text-gray-400 group-hover:text-accent transition-colors">
              {dir.initials ?? dir.name.slice(0, 2).toUpperCase()}
            </span>
          </div>
          <span class="text-sm font-semibold text-gray-400 group-hover:text-white transition-colors text-center inline-flex items-center gap-1">
            {dir.name}
            <ExternalLink class="w-3 h-3 opacity-60" aria-hidden="true" />
          </span>
        </a>
      ))
    }
  </div>
</SectionWrapper>
