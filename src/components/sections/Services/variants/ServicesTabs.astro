---
/**
 * Variant `tabs` — Alpine.js tab panel with service details.
 * Spec §2.3: services.json "variant":"tabs" must render this component.
 */
import type { ServicesData } from '../../../../data/types';
import { getSite } from '../../../../data/loaders';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import ResponsiveImage from '../../../ui/ResponsiveImage.astro';
import Button from '../../../ui/Button.astro';
import Check from '@lucide/astro/icons/check';

interface Props {
  data: ServicesData;
}

const { data } = Astro.props;
const site = getSite();
const enableLandings = site.features?.enable_landings !== false;
const firstId = data.services[0]?.id ?? '';
---

<SectionWrapper background="muted" id="services">
  <SectionHeader title={data.section_title} subtitle={data.section_subtitle} />

  <div
    class="max-w-5xl mx-auto"
    data-services-tabs
    x-data={`{ active: '${firstId}' }`}
  >
    <div
      class="flex flex-wrap gap-2 justify-center mb-8"
      role="tablist"
      aria-label="Services"
      data-reveal
    >
      {
        data.services.map((service) => (
          <button
            type="button"
            role="tab"
            :aria-selected={`active === '${service.id}'`}
            class="px-4 py-2 rounded-full text-sm font-semibold border transition-colors"
            :class={`active === '${service.id}' ? 'bg-primary text-white border-primary' : 'bg-light text-dark border-border hover:border-primary'`}
            @click={`active = '${service.id}'`}
          >
            {service.name}
          </button>
        ))
      }
    </div>

    {
      data.services.map((service, i) => (
        <div
          x-show={`active === '${service.id}'`}
          x-cloak
          role="tabpanel"
          class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center bg-light rounded-2xl p-6 md:p-8 shadow-sm"
          data-reveal={i === 0 ? '' : undefined}
        >
          <div class="relative aspect-[4/3] rounded-xl overflow-hidden">
            <ResponsiveImage
              src={service.image}
              alt={service.name}
              width={900}
              height={675}
              class="w-full h-full object-cover"
              sizes="(max-width: 768px) 100vw, 50vw"
            />
          </div>
          <div>
            <h3 class="font-heading text-2xl font-bold text-dark mb-3">
              {service.name}
            </h3>
            <p class="text-muted leading-relaxed mb-5">
              {service.full_description}
            </p>
            {service.highlights && service.highlights.length > 0 && (
              <ul class="space-y-2 mb-6">
                {service.highlights.map((h) => (
                  <li class="flex items-start gap-2 text-sm text-dark">
                    <Check class="w-4 h-4 text-accent mt-0.5 shrink-0" />
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            )}
            {enableLandings && (
              <Button href={`/services/${service.slug}`} variant="primary" size="md">
                View {service.name}
              </Button>
            )}
          </div>
        </div>
      ))
    }
  </div>
</SectionWrapper>

<style is:global>
  [x-cloak] {
    display: none !important;
  }
</style>
