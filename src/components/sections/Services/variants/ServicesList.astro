---
/**
 * Variant `list` — horizontal rows with image + description.
 */
import type { ServicesData } from '../../../../data/types';
import { getSite } from '../../../../data/loaders';
import { publishesServiceDetail } from '../../../../utils/routes';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import ResponsiveImage from '../../../ui/ResponsiveImage.astro';
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  data: ServicesData;
}

const { data } = Astro.props;
const site = getSite();
const showServiceDetail = publishesServiceDetail(site);
---

<SectionWrapper background="muted" id="services">
  <SectionHeader title={data.section_title} subtitle={data.section_subtitle} />

  <div class="space-y-6 max-w-5xl mx-auto">
    {
      data.services.map((service, i) => (
        <article
          data-reveal
          data-reveal-delay={String(i * 0.06)}
          class="group bg-light rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col sm:flex-row"
        >
          <div class="relative sm:w-56 md:w-64 lg:w-72 shrink-0 h-48 sm:h-auto overflow-hidden">
            <ResponsiveImage
              src={service.image}
              alt={service.name}
              width={640}
              height={480}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              sizes="(max-width: 640px) 100vw, 280px"
            />
          </div>
          <div class="flex flex-col justify-center p-6 md:p-8 flex-1">
            <h3 class="font-heading font-bold text-xl md:text-2xl text-dark mb-3 group-hover:text-primary transition-colors">
              {service.name}
            </h3>
            <p class="text-muted text-sm md:text-base leading-relaxed mb-4">
              {service.short_description}
            </p>
            {service.highlights && service.highlights.length > 0 && (
              <ul class="flex flex-wrap gap-2 mb-4">
                {service.highlights.map((h) => (
                  <li class="text-xs font-medium px-2.5 py-1 rounded-full bg-surface text-primary border border-border">
                    {h}
                  </li>
                ))}
              </ul>
            )}
            {showServiceDetail && (
              <a
                href={`/services/${service.slug}`}
                class="inline-flex items-center gap-1 text-accent font-semibold text-sm hover:text-primary transition-colors w-fit"
              >
                Learn more
                <ArrowRight class="w-4 h-4" />
              </a>
            )}
          </div>
        </article>
      ))
    }
  </div>
</SectionWrapper>
