---
/**
 * Variant `cards` — icon-forward bordered cards without heavy imagery.
 */
import type { ServicesData } from '../../../../data/types';
import { getSite } from '../../../../data/loaders';
import { resolveIcon } from '../../../icons/icon-map';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import Card from '../../../ui/Card.astro';
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  data: ServicesData;
}

const { data } = Astro.props;
const site = getSite();
const enableLandings = site.features?.enable_landings !== false;
---

<SectionWrapper background="default" id="services">
  <SectionHeader title={data.section_title} subtitle={data.section_subtitle} />

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {
      data.services.map((service, i) => {
        const Icon = resolveIcon(service.icon ?? 'hammer');
        return (
          <div data-reveal data-reveal-delay={String(i * 0.08)}>
            <Card as="article" variant="hover-lift" class="p-6 border border-border h-full">
              <div class="w-12 h-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center mb-4">
                <Icon class="w-6 h-6" />
              </div>
              <h3 class="font-heading font-bold text-lg text-dark mb-2">
                {service.name}
              </h3>
              <p class="text-muted text-sm leading-relaxed mb-4">
                {service.short_description}
              </p>
              {enableLandings && (
                <a
                  href={`/services/${service.slug}`}
                  class="inline-flex items-center gap-1 text-accent font-semibold text-sm hover:text-primary transition-colors"
                >
                  Details
                  <ArrowRight class="w-4 h-4" />
                </a>
              )}
            </Card>
          </div>
        );
      })
    }
  </div>
</SectionWrapper>
