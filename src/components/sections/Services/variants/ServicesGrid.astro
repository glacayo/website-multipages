---
/**
 * Variant `grid` — responsive card grid with images.
 */
import type { ServicesData } from '../../../../data/types';
import { getServicesPath, getSite } from '../../../../data/loaders';
import { publishesServiceDetail } from '../../../../utils/routes';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import ResponsiveImage from '../../../ui/ResponsiveImage.astro';
import Button from '../../../ui/Button.astro';
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  data: ServicesData;
}

const { data } = Astro.props;
const site = getSite();
const showServiceDetail = publishesServiceDetail(site);
const servicesPath = getServicesPath();
---

<SectionWrapper background="dark" id="services">
  <SectionHeader
    title={data.section_title}
    subtitle={data.section_subtitle}
    titleClass="!text-white"
    subtitleClass="!text-white/70"
  />

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
    {
      data.services.map((service, i) => (
        <article
          data-reveal
          data-reveal-delay={String(i * 0.08)}
          class="group bg-gradient-to-br from-primary to-dark border border-white/10 rounded-xl hover:border-white/30 hover:shadow-xl hover:shadow-accent/20 hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col"
        >
          <div class="relative h-48 md:h-52 overflow-hidden">
            <ResponsiveImage
              src={service.image}
              alt={service.name}
              width={800}
              height={520}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            />
          </div>
          <div class="p-5 md:p-6 flex flex-col flex-1">
            <h3 class="font-heading font-bold text-lg md:text-xl text-white mb-2">
              {service.name}
            </h3>
            <p class="text-white/70 text-sm leading-relaxed flex-1 mb-4">
              {service.short_description}
            </p>
            {showServiceDetail && (
              <a
                href={`/services/${service.slug}`}
                class="inline-flex items-center gap-1 text-accent font-semibold text-sm hover:text-white transition-colors"
              >
                Learn more
                <ArrowRight class="w-4 h-4" />
              </a>
            )}
          </div>
        </article>
      ))
    }
  </div>

  <div class="text-center mt-10 md:mt-14" data-reveal>
    <Button href={servicesPath} variant="primary" size="lg">
      View All Services
      <ArrowRight class="w-4 h-4" />
    </Button>
  </div>
</SectionWrapper>
