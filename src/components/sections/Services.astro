---
import content from '../../data/content.json';

const { company_name, services: allServices, section_headings, buttons } = content;
const { services: sHeadings } = section_headings;

const targetServices = ['Concrete', 'Paver', 'Masonry', 'Hardscape', 'Patios', 'Driveway'];
const services = allServices.filter(s => targetServices.includes(s.name));
---

<section class="relative bg-dark pt-16 md:pt-24 pb-16 md:pb-28">
  <!-- ╱ Top Shape Divider — slant white → dark -->
  <div class="absolute top-0 left-0 right-0 h-14 md:h-20 overflow-hidden pointer-events-none -translate-y-full z-10">
    <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Layer 1: accent semi-transparent, inverted direction -->
      <polygon points="0,30 0,60 1440,60" fill="#003060" opacity="0.35" />
      <!-- Layer 2: solid dark on top -->
      <polygon points="0,60 1440,0 1440,60" fill="#012141" />
    </svg>
  </div>

  <div class="container-site relative">
    <div class="text-center mb-12 md:mb-16" data-reveal>
      <p class="text-accent/80 font-semibold text-sm uppercase tracking-[0.2em] mb-3">
        {sHeadings.badge}
      </p>
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">
        {sHeadings.headline}
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        {sHeadings.subtitle_prefix}{company_name}{sHeadings.subtitle_suffix}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {services.map((service, i) => (
        <article
          data-reveal
          data-reveal-delay={String(i * 0.1)}
          class="shine-effect group bg-gradient-to-br from-accent to-primary border border-white/10 rounded-xl hover:border-white/30 hover:shadow-xl hover:shadow-accent/20 hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col"
        >
          <div class="relative h-48 md:h-52 overflow-hidden shimmer-bg">
            <img
              src={service.image}
              alt={service.name}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 shimmer-img"
              loading="lazy"
              onload="this.classList.add('loaded')"
            />
          </div>
          <div class="p-5 md:p-6 flex flex-col flex-1">
            <h3 class="font-heading font-bold text-lg md:text-xl text-white mb-2">
              {service.name}
            </h3>
            <p class="text-white/70 text-sm leading-relaxed flex-1">
              {service.short_text}
            </p>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-10 md:mt-14" data-reveal>
      <a
        href="/services"
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-accent text-white font-semibold rounded-md hover:bg-accent/85 hover:shadow-lg hover:shadow-accent/30 hover:-translate-y-0.5 transition-all duration-300 shine-effect"
      >
        {buttons.see_more_services}
        <i class="fa-solid fa-arrow-right text-sm"></i>
      </a>
    </div>
  </div>

  <!-- ╲ Bottom Shape Divider — slant dark → next section -->
  <div class="absolute bottom-0 left-0 right-0 h-14 md:h-20 overflow-hidden pointer-events-none translate-y-full z-10">
    <svg class="absolute top-0 w-full h-full" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Layer 1: accent semi-transparent, inverted direction -->
      <polygon points="0,0 0,30 1440,0" fill="#003060" opacity="0.35" />
      <!-- Layer 2: solid dark on top -->
      <polygon points="0,0 1440,60 1440,0" fill="#012141" />
    </svg>
  </div>
</section>
