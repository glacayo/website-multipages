---
import 'swiper/css';
import 'swiper/css/effect-fade';
import 'swiper/css/navigation';
import 'swiper/css/pagination';
import content from '../../data/content.json';

const { company_phone, hero_slides, buttons } = content;
const slides = hero_slides;
---

<div class="relative -mt-[5.5rem] md:-mt-[6.5rem]">
  <div class="hero-swiper swiper h-screen min-h-[650px]">
    <div class="swiper-wrapper">
      {slides.map((slide) => (
        <div class="swiper-slide relative overflow-hidden">
          <!-- Background Image -->
          <div class="absolute inset-0 shimmer-bg"></div>
          <div
            class="absolute inset-0 bg-cover bg-center scale-105"
            style={`background-image: url('${slide.image}')`}
          ></div>

          <!-- Overlay Gradient -->
          <div class={`absolute inset-0 bg-gradient-to-br ${slide.overlay}`}></div>

          <!-- Content -->
          <div class="relative z-10 container-site h-full grid place-items-center text-center text-white px-4 pt-16">
            <div class="swiper-slide-content max-w-4xl mx-auto">
              <p class="text-accent/90 font-semibold text-sm md:text-base uppercase tracking-[0.2em] mb-4 opacity-0 translate-y-6">
                {slide.tagline}
              </p>
              <h1 class="font-heading text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold mb-6 leading-[1.1] opacity-0 translate-y-8">
                {slide.headline}
              </h1>
              <p class="text-white/80 text-base md:text-lg max-w-xl mx-auto mb-8 opacity-0 translate-y-8">
                {slide.text}
              </p>
              <div class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 translate-y-8">
                <a
                  href="/contact-us"
                  class="px-8 py-4 bg-accent text-white font-bold rounded-md hover:bg-accent/85 hover:shadow-xl hover:shadow-accent/30 hover:-translate-y-1 transition-all duration-300 inline-flex items-center gap-2 shine-effect"
                >
                  <i class="fa-solid fa-calendar-check"></i>
                  {buttons.contact_us_today}
                </a>
                <a
                  href={`tel:${company_phone[0].replace(/\D/g, '')}`}
                  class="px-8 py-4 border-2 border-white/30 text-white font-bold rounded-md hover:bg-white hover:text-primary transition-all duration-300 inline-flex items-center gap-2 shine-effect"
                >
                  <i class="fa-solid fa-phone"></i>
                  {company_phone[0]}
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Navigation Arrows (hidden) -->
    <div class="swiper-button-prev !hidden lg:!flex !w-10 !h-10 after:!text-xl !text-white/60 hover:!text-accent !transition-colors"></div>
    <div class="swiper-button-next !hidden lg:!flex !w-10 !h-10 after:!text-xl !text-white/60 hover:!text-accent !transition-colors"></div>

    <!-- Pagination Dots -->
    <div class="swiper-pagination !bottom-8"></div>
  </div>

  <!-- Bottom Gradient to next section -->
  <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-gray-50 to-transparent pointer-events-none"></div>
</div>

<style>
  .swiper-pagination-bullet {
    width: 12px;
    height: 12px;
    background: rgba(255, 255, 255, 0.4);
    opacity: 1;
    transition: all 0.3s ease;
  }
  .swiper-pagination-bullet-active {
    background: #962e20;
    transform: scale(1.2);
  }
</style>

<script>
  import Swiper from 'swiper';
  import { EffectFade, Autoplay, Navigation, Pagination } from 'swiper/modules';

  const swiper = new Swiper('.hero-swiper', {
    modules: [EffectFade, Autoplay, Navigation, Pagination],
    effect: 'fade',
    fadeEffect: { crossFade: true },
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
    },
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
    loop: true,
    speed: 800,
  });

  const animateSlideContent = () => {
    const activeSlide = document.querySelector('.swiper-slide-active');
    if (!activeSlide) return;
    const elements = activeSlide.querySelectorAll('.swiper-slide-content > *');
    elements.forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 0.15}s`;
      el.classList.remove('opacity-0', 'translate-y-6', 'translate-y-8');
    });
  };

  swiper.on('slideChangeTransitionStart', () => {
    document.querySelectorAll('.swiper-slide-content > *').forEach((el) => {
      el.classList.add('opacity-0');
      el.classList.add('translate-y-6', 'translate-y-8');
    });
  });

  swiper.on('slideChangeTransitionEnd', () => animateSlideContent());

  setTimeout(() => animateSlideContent(), 300);
</script>

<style is:global>
  .swiper-slide-content > * {
    transition: opacity 0.7s ease, transform 0.7s ease;
    transition-delay: 0s;
  }
  .swiper-slide-content > .opacity-0 {
    opacity: 0 !important;
  }
</style>
