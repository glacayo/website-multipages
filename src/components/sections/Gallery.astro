---
import content from '../../data/content.json';

const { gallery_images, section_headings } = content;
const { gallery: gHeadings } = section_headings;

const images = gallery_images;
---

<section 
  x-data={`{ 
    open: false, 
    current: 0,
    total: ${images.length},
    fullImages: ${JSON.stringify(images)},
    prev() { this.current = (this.current - 1 + this.total) % this.total },
    next() { this.current = (this.current + 1) % this.total },
    show(i) { this.current = i; this.open = true; document.body.style.overflow = 'hidden' },
    close() { this.open = false; document.body.style.overflow = '' },
  }`}
  @keydown.escape.window="close()"
  class="bg-gray-100"
>

  <!-- Header -->
  <div class="pt-16 md:pt-24 pb-10 md:pb-14">
    <div class="container-site" data-reveal>
      <div class="text-center max-w-2xl mx-auto">
        <span class="inline-flex items-center gap-2 text-accent font-semibold text-sm uppercase tracking-[0.2em] mb-3">
          <span class="w-8 h-[2px] bg-accent"></span>
          {gHeadings.badge}
        </span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-dark mb-4">
          {gHeadings.headline_line1}<span class="text-primary">{gHeadings.headline_line2}</span>
        </h2>
        <p class="text-gray-500 text-base md:text-lg">{gHeadings.subtitle}</p>
      </div>
    </div>
  </div>

  <!-- Full Width Grid -->
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5">
    {images.map((src, i) => (
      <div 
        @click={`show(${i})`}
        data-reveal 
        data-reveal-delay={String((i % 5) * 0.08)} 
        class="gallery-item group relative overflow-hidden aspect-[4/3] cursor-pointer"
      >
        <div class="absolute inset-0 shimmer-bg"></div>
        <img
          src={src}
          alt={gHeadings.image_alt_prefix + (i + 1)}
          class="relative z-10 w-full h-full object-cover transition-transform duration-600 ease-out group-hover:scale-110"
          loading="lazy"
        />
        
        <div class="absolute inset-0 z-20 bg-dark/0 group-hover:bg-dark/70 transition-all duration-400 flex flex-col items-center justify-center gap-2 opacity-0 group-hover:opacity-100">
          <i class="fa-solid fa-magnifying-glass text-white text-2xl md:text-3xl drop-shadow-lg scale-75 group-hover:scale-100 transition-transform duration-400"></i>
          <span class="text-white font-semibold text-sm tracking-wider drop-shadow-lg translate-y-2 group-hover:translate-y-0 transition-transform duration-400">
            {gHeadings.zoom_text}
          </span>
        </div>
      </div>
    ))}
  </div>

  <!-- Lightbox Modal -->
  <div 
    x-show="open" 
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 z-[100] flex items-center justify-center p-4 md:p-8 bg-dark/95"
    @click.self="close()"
  >
    <button @click="close()" class="absolute top-4 right-4 md:top-6 md:right-6 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10">
      <i class="fa-solid fa-xmark text-lg"></i>
    </button>
    <button @click.stop="prev()" class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10">
      <i class="fa-solid fa-chevron-left text-lg"></i>
    </button>
    <div class="max-w-5xl max-h-[85vh] w-full h-full flex items-center justify-center">
      <template x-for="(img, i) in fullImages" :key="i">
        <img 
          :src="img" 
          alt="Gallery image"
          x-show="current === i"
          class="max-w-full max-h-[85vh] object-contain rounded-lg"
        />
      </template>
    </div>
    <button @click.stop="next()" class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10">
      <i class="fa-solid fa-chevron-right text-lg"></i>
    </button>
    <div class="absolute bottom-4 md:bottom-6 left-1/2 -translate-x-1/2 text-white/60 text-sm font-medium">
      <span x-text="current + 1"></span> / <span x-text="total"></span>
    </div>
  </div>
</section>
