---
/**
 * Home about teaser. Content derived from business.json.
 */
import Button from '../ui/Button.astro';
import ResponsiveImage from '../ui/ResponsiveImage.astro';
import { getAboutPath, getBusiness } from '../../data/loaders';

const business = getBusiness();
const aboutHref = getAboutPath();
---

<section id="about" class="relative overflow-hidden py-20 md:py-28">
  <div class="absolute inset-0">
    <ResponsiveImage
      src="./images/about/workshop.jpg"
      alt={`${business.name} workshop and team`}
      width={1920}
      height={1080}
      class="h-full w-full object-cover"
    />
  </div>
  <div class="absolute inset-0 bg-gradient-to-r from-dark/95 via-dark/80 to-dark/40"></div>

  <div class="container-site relative z-10">
    <div class="max-w-2xl">
      <span
        class="mb-3 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.2em] text-accent"
        data-reveal
      >
        <span class="h-[2px] w-8 bg-accent"></span>
        About us
      </span>

      <h2
        class="font-heading mb-6 text-3xl font-bold leading-tight text-white md:text-4xl lg:text-5xl"
        data-reveal
        data-reveal-delay="0.1"
      >
        {business.years_experience} years of
        <span class="text-accent"> building excellence</span>
      </h2>

      <div
        class="mb-8 space-y-4 text-base leading-relaxed text-white/80 md:text-lg"
        data-reveal
        data-reveal-delay="0.2"
      >
        <p>
          {business.name} is a trusted {business.type_of_services.toLowerCase()} contractor
          serving {business.service_area}.
        </p>
        <p>
          {business.tagline} {business.license}. {business.insurance}
        </p>
      </div>

      <div data-reveal data-reveal-delay="0.35">
        {aboutHref !== '/#about' && (
          <Button href={aboutHref} variant="primary" size="md">
            Learn more about us
          </Button>
        )}
      </div>
    </div>
  </div>
</section>
