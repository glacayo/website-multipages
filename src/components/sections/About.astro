---
import content from '../../data/content.json';

const { company_name, about_content, company_years_experience, section_headings, buttons } = content;
const { about: aHeadings } = section_headings;
---

<section class="relative py-20 md:py-32 overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 shimmer-bg">
    <img
      src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=1920&q=80&fit=crop"
      alt=""
      class="w-full h-full object-cover shimmer-img"
      loading="lazy"
      onload="this.classList.add('loaded')"
    />
  </div>

  <!-- Dark Overlay -->
  <div class="absolute inset-0 bg-dark/80 bg-gradient-to-r from-dark/95 via-dark/80 to-dark/30"></div>

  <!-- Content -->
  <div class="container-site relative z-10">
    <div class="max-w-2xl">
      <span class="inline-flex items-center gap-2 text-accent/90 font-semibold text-sm uppercase tracking-[0.2em] mb-3" data-reveal>
        <span class="w-8 h-[2px] bg-accent/90"></span>
        {aHeadings.badge}
      </span>

      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-[1.15] mb-6" data-reveal data-reveal-delay="0.1">
        {company_years_experience}<br/>
        <span class="text-accent">{aHeadings.headline_suffix}</span>
      </h2>

      <div class="space-y-4 text-white/80 text-base md:text-lg leading-relaxed mb-8" data-reveal data-reveal-delay="0.2">
        <p>{about_content[0]}</p>
        <p>{about_content[1]}</p>
      </div>

      <div data-reveal data-reveal-delay="0.35">
        <a
          href="/about-us"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-accent text-white font-semibold rounded-md hover:bg-accent/85 hover:shadow-lg hover:shadow-accent/30 hover:-translate-y-0.5 transition-all duration-300 shine-effect"
        >
          {buttons.learn_more_about_us}
          <i class="fa-solid fa-arrow-right text-sm"></i>
        </a>
      </div>
    </div>
  </div>
</section>
