---
import 'swiper/css';
import 'swiper/css/autoplay';
import content from '../../data/content.json';

const { company_name, testimonials, section_headings } = content;
const { testimonials: tHeadings } = section_headings;
---

<section class="relative py-16 md:py-24 bg-white">
  <div class="container-site">
    
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14" data-reveal>
      <span class="inline-flex items-center gap-2 text-accent font-semibold text-sm uppercase tracking-[0.2em] mb-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        {tHeadings.badge}
      </span>
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-dark mb-4">
        {tHeadings.headline_line1}<span class="text-primary">{tHeadings.headline_line2}</span>
      </h2>
      <p class="text-gray-500 text-base md:text-lg mb-6">
        {tHeadings.subtitle_prefix}{company_name}{tHeadings.subtitle_suffix}
      </p>
      
      <!-- Star Rating -->
      <div class="flex flex-col items-center gap-1">
        <div class="flex items-center gap-0.5 text-amber-400">
          {Array(5).fill(null).map(() => <i class="fa-solid fa-star"></i>)}
        </div>
        <p class="text-dark font-bold text-lg">{tHeadings.rating_label}</p>
        <p class="text-gray-400 text-sm">{tHeadings.rating_source}</p>
      </div>
    </div>

    <!-- Carousel -->
    <div data-reveal data-reveal-delay="0.15">
      <div class="testimonial-swiper swiper w-full max-w-full overflow-hidden px-1 equal-height-swiper">
        <div class="swiper-wrapper">
          {testimonials.map((t) => (
            <div class="swiper-slide flex h-auto py-2">
              <div class="testimonial-card bg-gradient-to-br from-gray-50 to-white border border-gray-100 rounded-2xl p-6 md:p-7 shadow-sm flex flex-col flex-1 mx-1">
                <div class="flex gap-0.5 text-amber-400 mb-4">
                  {Array(t.stars).fill(null).map(() => <i class="fa-solid fa-star text-sm"></i>)}
                </div>
                <blockquote class="text-dark/80 text-sm md:text-base leading-relaxed mb-5 flex-1">
                  &ldquo;{t.quote}&rdquo;
                </blockquote>
                <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
                  <div class="w-9 h-9 rounded-full bg-accent flex items-center justify-center text-white font-bold text-xs flex-shrink-0">
                    {t.avatar}
                  </div>
                  <div>
                    <p class="font-semibold text-dark text-sm">{t.name}</p>
                    <p class="text-gray-400 text-xs">{t.location}</p>
                  </div>
                  <span class="ml-auto text-[10px] text-gray-400 bg-gray-100 px-2 py-1 rounded-full">{t.service}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
        
        <!-- Dots -->
        <div class="flex items-center justify-center gap-2 mt-8">
          {testimonials.map((_, i) => (
            <button
              class="testimonial-dot w-2.5 h-2.5 rounded-full bg-gray-300 transition-all duration-300"
              data-index={i}
              aria-label={`Testimonial ${i + 1}`}
            ></button>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .equal-height-swiper .swiper-wrapper {
    align-items: stretch;
  }
  .equal-height-swiper .swiper-slide {
    height: auto !important;
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Autoplay } from 'swiper/modules';

  const dots: NodeListOf<HTMLElement> = document.querySelectorAll('.testimonial-dot');

  function setActiveDot(index: number) {
    dots.forEach((d, i) => {
      d.classList.toggle('!bg-accent', i === index);
      d.classList.toggle('!w-8', i === index);
    });
  }

  const swiper = new Swiper('.testimonial-swiper', {
    modules: [Autoplay],
    slidesPerView: 1,
    spaceBetween: 20,
    loop: true,
    speed: 600,
    autoHeight: true,
    autoplay: {
      delay: 4000,
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    },
    breakpoints: {
      768: { slidesPerView: 2, spaceBetween: 24 },
    },
    on: {
      init() { equalizeCards(); },
      slideChange(s) {
        setActiveDot(s.realIndex);
        setTimeout(equalizeCards, 50);
      },
      resize() { equalizeCards(); },
    },
  });

  function equalizeCards() {
    const cards = document.querySelectorAll<HTMLElement>('.testimonial-card');
    cards.forEach(c => c.style.height = 'auto');
    const max = Math.max(...Array.from(cards).map(c => c.offsetHeight));
    cards.forEach(c => c.style.height = max + 'px');
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = parseInt(dot.getAttribute('data-index') || '0');
      swiper.slideToLoop(idx);
    });
  });

  setActiveDot(0);
  setTimeout(equalizeCards, 200);
</script>
