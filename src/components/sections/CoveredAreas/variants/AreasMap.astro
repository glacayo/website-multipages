---
/**
 * Variant `map` — areas overlaid on a decorative map-style background.
 * No third-party map embed; static visual suitable for marketing templates.
 */
import type { AreasData } from '../../../../data/types';
import SectionHeader from '../../../ui/SectionHeader.astro';
import MapPin from '@lucide/astro/icons/map-pin';

interface Props {
  data: AreasData;
}

const { data } = Astro.props;
---

<section class="relative py-20 md:py-28 overflow-hidden" id="areas" data-areas-map>
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-surface to-accent/10"></div>
  <div
    class="absolute inset-0 opacity-[0.07] pointer-events-none"
    style="background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0); background-size: 28px 28px;"
  >
  </div>

  <div class="container-site relative z-10">
    <SectionHeader title={data.section_title} subtitle={data.section_subtitle} />

    <div class="relative max-w-4xl mx-auto rounded-2xl border border-border bg-light/80 backdrop-blur-sm shadow-lg p-6 md:p-10">
      {
        data.service_radius && (
          <p class="text-center text-muted text-sm mb-6" data-reveal>
            {data.service_radius}
          </p>
        )
      }

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 md:gap-5">
        {
          data.areas.map((area, i) => (
            <div
              data-reveal
              data-reveal-delay={String(i * 0.06)}
              class="group bg-light rounded-xl border border-border py-5 px-4 text-center hover:border-primary/40 hover:shadow-md hover:-translate-y-1 transition-all duration-300"
            >
              <MapPin class="w-5 h-5 text-accent mx-auto mb-2 group-hover:scale-110 transition-transform" />
              <span class="block font-semibold text-dark text-sm md:text-base">
                {area.name}
              </span>
              {area.county && (
                <span class="block text-muted text-xs mt-1">{area.county}</span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
