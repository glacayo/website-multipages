---
/**
 * Variant `columns` — multi-column text list of areas + primary city callout.
 */
import type { AreasData } from '../../../../data/types';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import Check from '@lucide/astro/icons/check';

interface Props {
  data: AreasData;
}

const { data } = Astro.props;
---

<SectionWrapper background="default" id="areas">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
    <div class="lg:col-span-5" data-reveal>
      <SectionHeader
        title={data.section_title}
        subtitle={data.section_subtitle}
        align="left"
        class="!mb-4"
      />
      {
        data.service_radius && (
          <p class="text-muted text-sm mb-4">{data.service_radius}</p>
        )
      }
      {
        data.primary_city && (
          <p class="inline-flex items-center gap-2 text-sm font-semibold text-primary bg-primary/10 px-3 py-1.5 rounded-full">
            Primary city: {data.primary_city}
          </p>
        )
      }
    </div>

    <div class="lg:col-span-7">
      <ul class="columns-1 sm:columns-2 gap-x-8 space-y-0">
        {
          data.areas.map((area, i) => (
            <li
              data-reveal
              data-reveal-delay={String(i * 0.04)}
              class="flex items-start gap-2 py-2.5 break-inside-avoid border-b border-border/60"
            >
              <Check class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" aria-hidden="true" />
              <span class="text-dark text-sm md:text-base">
                <span class="font-semibold">{area.name}</span>
                {area.state ? `, ${area.state}` : ''}
                {area.county ? (
                  <span class="text-muted"> · {area.county}</span>
                ) : null}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</SectionWrapper>
