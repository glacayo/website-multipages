---
import content from '../../data/content.json';

const { company_name, company_cover_area, covered_cities, section_headings } = content;
const { covered_areas: caHeadings } = section_headings;

const cities = covered_cities.map(city => ({ name: city }));
---

<section class="relative py-20 md:py-28 overflow-hidden">
  <!-- Map Background -->
  <div class="absolute inset-0 shimmer-bg">
    <img
      src="https://images.unsplash.com/photo-1524661135-423995f22d0b?w=1920&q=80&fit=crop"
      alt=""
      class="w-full h-full object-cover shimmer-img"
      loading="lazy"
      onload="this.classList.add('loaded')"
    />
  </div>

  <!-- Light Overlay -->
  <div class="absolute inset-0 bg-white/85"></div>

  <!-- Content -->
  <div class="container-site relative z-10">
    <div class="text-center mb-12 md:mb-16" data-reveal>
      <span class="inline-flex items-center gap-2 text-accent font-semibold text-sm uppercase tracking-[0.2em] mb-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        {caHeadings.badge}
      </span>
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-dark mb-4">
        {caHeadings.headline_line1}<span class="text-primary">{caHeadings.headline_line2}</span>
      </h2>
      <p class="text-gray-600 text-base md:text-lg max-w-2xl mx-auto">
        {caHeadings.subtitle_prefix}
      </p>
    </div>

    <!-- Cities Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 md:gap-5 max-w-4xl mx-auto">
      {cities.map((city, i) => (
        <div
          data-reveal
          data-reveal-delay={String(i * 0.08)}
          class="group bg-white rounded-xl border border-gray-200 py-5 px-4 text-center hover:border-primary/40 hover:shadow-md hover:-translate-y-1 transition-all duration-300"
        >
          <i class="fa-solid fa-location-dot text-accent text-lg mb-2 block group-hover:scale-110 transition-transform duration-300"></i>
          <span class="block font-semibold text-dark text-sm md:text-base">
            {city.name}
          </span>
        </div>
      ))}
      <div
        data-reveal
        data-reveal-delay={String(cities.length * 0.08)}
        class="md:col-span-4 flex items-center justify-center py-2"
      >
        <span class="text-gray-400 text-sm italic">
          {caHeadings.more_areas}
        </span>
      </div>
    </div>
  </div>
</section>
