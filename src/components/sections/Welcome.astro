---
/**
 * Home welcome / intro section using business.json + about image assets.
 */
import Button from '../ui/Button.astro';
import ResponsiveImage from '../ui/ResponsiveImage.astro';
import { getBusiness } from '../../data/loaders';

const business = getBusiness();
const yearsDigits = business.years_experience.replace(/[^\d]/g, '') || '10';

const stats = [
  { value: Number(yearsDigits) || 10, suffix: '+', label: 'Years experience' },
  { value: business.services_offered.length, suffix: '', label: 'Core services' },
  { value: business.payment_methods.length, suffix: '', label: 'Payment options' },
];
---

<section class="relative overflow-hidden bg-white py-16 md:py-28">
  <div class="container-site relative z-10">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[5fr_7fr] lg:gap-20">
      <div class="relative mx-auto max-w-md lg:mx-0 lg:max-w-none">
        <div class="relative overflow-hidden rounded-2xl shadow-xl" data-reveal>
          <ResponsiveImage
            src="./images/about/team.jpg"
            alt={`${business.name} team at work`}
            width={800}
            height={960}
            class="h-[320px] w-full object-cover md:h-[420px] lg:h-[480px]"
          />
        </div>
        <div
          class="absolute -bottom-5 right-6 z-20 min-w-[120px] rounded-xl bg-accent px-6 py-4 text-center text-white shadow-2xl sm:right-10 lg:-right-8 lg:-bottom-6"
          data-reveal
          data-reveal-delay="0.3"
        >
          <span class="font-heading block text-3xl font-extrabold leading-none md:text-4xl">
            {business.years_experience}
          </span>
          <span class="mt-1 block text-xs font-medium leading-tight text-white/85 md:text-sm">
            Years of experience
          </span>
        </div>
      </div>

      <div>
        <span
          class="mb-3 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.2em] text-accent"
          data-reveal
          data-reveal-delay="0.1"
        >
          <span class="h-[2px] w-8 bg-accent"></span>
          Welcome
        </span>

        <h2
          class="font-heading mb-4 text-3xl font-bold leading-tight text-dark md:text-4xl lg:text-5xl"
          data-reveal
          data-reveal-delay="0.2"
        >
          Local craftsmanship for
          <span class="text-primary"> outdoor living</span>
        </h2>

        <p class="mb-6 text-lg text-muted" data-reveal data-reveal-delay="0.3">
          Proudly serving {business.service_area}.
        </p>

        <div class="space-y-4 leading-relaxed text-muted" data-reveal data-reveal-delay="0.4">
          <p>
            {business.name} specializes in {business.type_of_services.toLowerCase()}.
            {business.tagline}
          </p>
          <p>
            {business.license}. {business.insurance} {business.free_estimate}.
          </p>
        </div>

        <div
          class="mt-8 grid grid-cols-3 gap-3 border-t border-border pt-8 md:gap-4"
          data-reveal
          data-reveal-delay="0.55"
        >
          {
            stats.map((stat) => (
              <div class="rounded-xl border border-border px-2 py-4 text-center">
                <span class="font-heading block text-2xl font-bold text-primary md:text-3xl">
                  {stat.value}
                  {stat.suffix}
                </span>
                <span class="mt-1 block text-[11px] leading-tight text-muted md:text-xs">
                  {stat.label}
                </span>
              </div>
            ))
          }
        </div>

        <div class="mt-8" data-reveal data-reveal-delay="0.7">
          <Button href="/about-us" variant="secondary" size="md">
            Learn more about us
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
