---
import content from '../../data/content.json';

const { company_estimate, section_headings, buttons } = content;
const { cta: ctaHeadings } = section_headings;
---

<section class="bg-accent relative overflow-hidden">
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 24px 24px;"></div>
  </div>

  <div class="container-site relative z-10 py-10 md:py-12">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-12 items-center">
      <div>
        <h2 class="font-heading text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-2">
          {ctaHeadings.headline}
        </h2>
        <p class="text-white/80 text-base md:text-lg">
          {company_estimate}{ctaHeadings.subtitle_suffix}
        </p>
      </div>

      <a
        href="/contact-us"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-accent font-bold rounded-md hover:bg-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 shine-effect whitespace-nowrap"
      >
        <i class="fa-solid fa-paper-plane"></i>
        {buttons.contact_us_today}
      </a>
    </div>
  </div>
</section>
