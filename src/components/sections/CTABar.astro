---
/**
 * Site-wide call-to-action bar. Data from business.json only.
 */
import Button from '../ui/Button.astro';
import { getBusiness } from '../../data/loaders';

const business = getBusiness();
---

<section class="relative overflow-hidden bg-accent">
  <div
    class="pointer-events-none absolute inset-0 opacity-10"
    aria-hidden="true"
    style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 24px 24px;"
  >
  </div>

  <div class="container-site relative z-10 py-10 md:py-12">
    <div class="grid grid-cols-1 items-center gap-6 md:grid-cols-[1fr_auto] md:gap-12">
      <div>
        <h2 class="font-heading mb-2 text-2xl font-bold text-white md:text-3xl lg:text-4xl">
          Ready to start your project?
        </h2>
        <p class="text-base text-white/85 md:text-lg">
          {business.free_estimate}. Serving {business.service_area}.
        </p>
      </div>

      <Button
        href="/contact-us"
        variant="primary"
        size="lg"
        class="bg-white text-accent hover:bg-light hover:text-accent whitespace-nowrap"
      >
        Contact us today
      </Button>
    </div>
  </div>
</section>
