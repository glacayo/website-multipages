---
/**
 * Variant `compact` — dense two-column Q&A list without accordion chrome.
 */
import type { FAQData } from '../../../../data/types';
import SectionWrapper from '../../../ui/SectionWrapper.astro';
import SectionHeader from '../../../ui/SectionHeader.astro';
import HelpCircle from '@lucide/astro/icons/circle-question-mark';

interface Props {
  data: FAQData;
}

const { data } = Astro.props;
---

<SectionWrapper background="default" id="faq">
  <SectionHeader title={data.section_title} subtitle={data.section_subtitle} />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5 max-w-5xl mx-auto">
    {
      data.faqs.map((faq, i) => (
        <article
          data-reveal
          data-reveal-delay={String(i * 0.05)}
          class="flex gap-3 p-4 rounded-lg border border-border bg-surface/50"
        >
          <HelpCircle class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" aria-hidden="true" />
          <div class="min-w-0">
            <h3 class="font-semibold text-dark text-sm mb-1">{faq.q}</h3>
            <p class="text-muted text-xs md:text-sm leading-relaxed">{faq.a}</p>
          </div>
        </article>
      ))
    }
  </div>
</SectionWrapper>
