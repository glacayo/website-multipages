---
/**
 * Variant `three` — centered headline over full-bleed background image.
 */
import type { HeroData } from '../../../../data/types';
import ResponsiveImage from '../../../ui/ResponsiveImage.astro';
import Button from '../../../ui/Button.astro';

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
const slide = data.slides[0];

const overlayClass: Record<string, string> = {
  dark: 'bg-dark/75',
  primary: 'bg-primary/80',
  accent: 'bg-accent/70',
  none: 'bg-dark/40',
};
---

{
  slide && (
    <section class="relative min-h-[70vh] md:min-h-[80vh] flex items-center" aria-label="Hero">
      <div class="absolute inset-0">
        <ResponsiveImage
          src={slide.image}
          alt={slide.image_alt}
          width={1920}
          height={1080}
          lcp
          class="w-full h-full object-cover"
          sizes="100vw"
        />
      </div>
      <div
        class:list={[
          'absolute inset-0',
          overlayClass[slide.overlay ?? 'dark'] ?? overlayClass.dark,
        ]}
      />
      <div class="relative z-10 container-site py-24 text-center text-white">
        <p
          class="text-accent/90 font-semibold text-sm md:text-base uppercase tracking-[0.2em] mb-4"
          data-reveal
        >
          {slide.tagline}
        </p>
        <h1
          class="font-heading text-4xl sm:text-5xl md:text-6xl font-extrabold mb-6 max-w-3xl mx-auto leading-tight"
          data-reveal
        >
          {slide.headline}
        </h1>
        <p class="text-white/85 text-lg max-w-2xl mx-auto mb-10" data-reveal>
          {slide.text}
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal>
          <Button href={slide.cta_primary.href} variant="primary" size="lg">
            {slide.cta_primary.label}
          </Button>
          {slide.cta_secondary && (
            <Button
              href={slide.cta_secondary.href}
              variant="outline"
              size="lg"
              class="!border-white/40 !text-white hover:!bg-white hover:!text-primary"
            >
              {slide.cta_secondary.label}
            </Button>
          )}
        </div>
      </div>
    </section>
  )
}
