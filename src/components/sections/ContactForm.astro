---
import content from '../../data/content.json';

const { company_name, company_address, services: allServices, section_headings, buttons } = content;
const { contact_form: cfHeadings } = section_headings;
---

<section class="py-16 md:py-24 bg-gray-100">
  <div class="container-site">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16" data-reveal>
      <span class="inline-flex items-center gap-2 text-accent font-semibold text-sm uppercase tracking-[0.2em] mb-3">
        <span class="w-8 h-[2px] bg-accent"></span>
        {cfHeadings.badge}
      </span>
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-dark mb-4">
        {cfHeadings.headline}
      </h2>
      <p class="text-gray-500 text-base md:text-lg">
        {cfHeadings.subtitle}
      </p>
    </div>

    <!-- Map + Form Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 bg-white rounded-2xl shadow-lg overflow-hidden">
      
      <!-- Left: Map -->
      <div class="relative min-h-[350px] lg:min-h-full order-2 lg:order-1" data-reveal>
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3192.2440598230144!2d-76.3417!3d36.7951!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzbCsDQ5JzU3LjAiTiA3NsKwMjInMjIuOCJX!5e0!3m2!1sen!2sus!4v1680000000000"
          width="100%"
          height="100%"
          class="absolute inset-0 border-0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={cfHeadings.map_title}
        ></iframe>
        
        <!-- Overlay info card on map (mobile) -->
        <div class="absolute bottom-4 left-4 right-4 bg-dark/90 backdrop-blur-sm text-white rounded-xl p-4 lg:hidden">
          <div class="flex items-start gap-3">
            <i class="fa-solid fa-location-dot text-accent mt-0.5"></i>
            <div>
              <p class="text-sm font-semibold">{company_name}</p>
              <p class="text-xs text-white/70">{company_address}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="p-6 md:p-10 order-1 lg:order-2" data-reveal data-reveal-delay="0.15">
        
        <!-- Form -->
        <form class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input 
              type="text" 
              placeholder={cfHeadings.name_placeholder}
              required
              class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
            />
            <input 
              type="email" 
              placeholder={cfHeadings.email_placeholder}
              required
              class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
            />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input 
              type="tel" 
              placeholder={cfHeadings.phone_placeholder}
              class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
            />
            <select 
              class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
            >
              <option value="">{cfHeadings.service_default}</option>
              {allServices.map(s => (
                <option value={s.name.toLowerCase().replace(/\s+/g, '-')}>{s.name}</option>
              ))}
            </select>
          </div>
          <textarea 
            placeholder={cfHeadings.message_placeholder}
            rows="4"
            required
            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors resize-none"
          ></textarea>
          <button 
            type="submit"
            class="w-full px-8 py-3.5 bg-accent text-white font-semibold rounded-lg hover:bg-accent/85 hover:shadow-lg hover:shadow-accent/20 transition-all duration-300 shine-effect"
          >
            <i class="fa-solid fa-paper-plane mr-2"></i>
            {buttons.send_message}
          </button>
        </form>
      </div>

    </div>

  </div>
</section>
