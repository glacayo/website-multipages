---
/**
 * BlogCard - Display a single blog post in a card format
 */
import type { BlogPost } from '../../data/types';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

// Format date
const formatDate = (dateStr: string): string => {
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
  } catch {
    return dateStr;
  }
};

const postUrl = `/blog/${post.slug}`;
const imageUrl = `/images/${post.image_filename}`;
---

<article class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 overflow-hidden flex flex-col h-full border border-gray-100">
  <!-- Featured Image -->
  <a href={postUrl} class="block overflow-hidden aspect-video" tabindex="-1" aria-hidden="true">
    <img
      src={imageUrl}
      alt={post.headline}
      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
  </a>

  <div class="p-6 flex flex-col flex-1">
    <!-- Category Badge -->
    <div class="mb-3">
      <span class="inline-block bg-primary/10 text-primary text-xs font-semibold px-3 py-1 rounded-full">
        {post.category}
      </span>
    </div>

    <!-- Headline -->
    <h3 class="text-xl font-bold text-dark mb-3 line-clamp-2">
      <a href={postUrl} class="hover:text-accent transition-colors duration-200 cursor-pointer">
        {post.headline}
      </a>
    </h3>

    <!-- Excerpt -->
    <p class="text-text-secondary text-sm mb-4 line-clamp-3 flex-1">
      {post.excerpt}
    </p>

    <!-- Meta: Date, Author, Reading Time -->
    <div class="flex items-center gap-3 text-xs text-text-secondary border-t border-gray-100 pt-4">
      <time datetime={post.date}>
        {formatDate(post.date)}
      </time>
      <span class="text-gray-300" aria-hidden="true">|</span>
      <span>{post.reading_time}</span>
      <span class="text-gray-300" aria-hidden="true">|</span>
      <span>{post.author}</span>
    </div>

    <!-- Read More Link -->
    <a
      href={postUrl}
      class="inline-flex items-center gap-2 text-accent font-semibold mt-4 hover:gap-3 transition-all duration-200 cursor-pointer"
      aria-label={`Read more: ${post.headline}`}
    >
      Read More
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</article>
