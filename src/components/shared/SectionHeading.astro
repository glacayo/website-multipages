---
/**
 * SectionHeading - Reusable section heading component
 * Displays title, optional subtitle, and optional decorative line
 */
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center' | 'right';
  className?: string;
}

const {
  title,
  subtitle,
  align = 'center',
  className = '',
} = Astro.props;

// Alignment classes
const alignClasses = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right',
};

const containerAlign = alignClasses[align];
const textAlignClass = align === 'center' ? 'mx-auto' : align === 'right' ? 'ml-auto' : '';
---

<div class={`mb-10 ${containerAlign} ${className}`}>
  <h2 class={`text-3xl md:text-4xl font-bold text-dark mb-4 ${textAlignClass}`}>
    {title}
  </h2>

  {subtitle && (
    <p class="text-text-secondary text-lg leading-relaxed" class:list={[textAlignClass]}>
      {subtitle}
    </p>
  )}

  <!-- Decorative line -->
  {align === 'center' && (
    <div class="mt-6 mx-auto w-20 h-1 bg-accent rounded-full"></div>
  )}
  {align === 'left' && (
    <div class="mt-6 w-20 h-1 bg-accent rounded-full"></div>
  )}
  {align === 'right' && (
    <div class="mt-6 ml-auto w-20 h-1 bg-accent rounded-full"></div>
  )}
</div>