---
import Badge from './Badge.astro';

interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
  titleClass?: string;
  subtitleClass?: string;
}

const {
  badge,
  title,
  subtitle,
  align = 'center',
  class: className = '',
  titleClass = '',
  subtitleClass = '',
} = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
---

<div class:list={['max-w-2xl mb-10 md:mb-14', alignClass, className]} data-reveal>
  {
    badge && (
      <div class:list={['mb-3', align === 'center' && 'flex justify-center']}>
        <Badge text={badge} />
      </div>
    )
  }
  <h2
    class:list={[
      'font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-dark mb-4',
      titleClass,
    ]}
  >
    {title}
  </h2>
  {
    subtitle && (
      <p class:list={['text-muted text-base md:text-lg', subtitleClass]}>{subtitle}</p>
    )
  }
  <slot />
</div>
