---
interface Props {
  name: string;
  label: string;
  type?:
    | 'text'
    | 'email'
    | 'tel'
    | 'url'
    | 'password'
    | 'number'
    | 'search'
    | 'date'
    | 'time'
    | 'hidden';
  placeholder?: string;
  required?: boolean;
  value?: string;
  autocomplete?: string;
  class?: string;
  inputClass?: string;
  id?: string;
}

const {
  name,
  label,
  type = 'text',
  placeholder,
  required = false,
  value,
  autocomplete,
  class: className = '',
  inputClass = '',
  id = name,
} = Astro.props;
---

<label class:list={['block space-y-1.5', className]} for={id}>
  <span class="text-sm font-medium text-dark">
    {label}
    {required && <span class="text-accent" aria-hidden="true">*</span>}
  </span>
  <input
    id={id}
    name={name}
    type={type}
    placeholder={placeholder}
    required={required}
    value={value}
    autocomplete={autocomplete}
    class:list={[
      'w-full rounded-md border border-border bg-light px-4 py-2.5 text-dark placeholder:text-muted',
      'focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20',
      'transition-colors duration-200',
      inputClass,
    ]}
  />
</label>
