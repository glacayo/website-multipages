---
/**
 * Footer - Site footer component
 * Displays company info, service links, social links, and legal info
 */
import { getSiteContent } from '../../data/loaders';

interface Props {
  currentPath?: string;
}

const content = getSiteContent();

const footerServices = content.services?.slice(0, 6) || [];

const socialLinks = [
  { href: content.social_media?.facebook || '#', label: 'Facebook', icon: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
  { href: content.social_media?.google || '#', label: 'Google', icon: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93s3.06-7.44 7-7.93v15.86zm2-15.86c1.03.13 2 .45 2.87.93H13v-.93zM13 7h5.24c.25.31.48.65.68 1H13V7zm0 3h6.74c.08.33.15.66.19 1H13v-1zm0 3h6.93c-.04.34-.11.67-.19 1H13v-1zm0 3h5.93c-.19.35-.43.69-.68 1H13v-1zm0 3h2.87c-3.94.49-7 3.85-7 7.93s3.06 7.44 7 7.93v-15.86z' },
  { href: content.social_media?.instagram || '#', label: 'Instagram', icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
  { href: content.social_media?.youtube || '#', label: 'YouTube', icon: 'M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z' },
  { href: content.social_media?.tiktok || '#', label: 'TikTok', icon: 'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-white">
  <!-- Main Footer Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <img
            src="/images/logo.png"
            alt="WG Masonry & Hardscape 757"
            class="h-16 w-auto brightness-0 invert"
          />
        </a>
        <p class="text-gray-300 text-sm leading-relaxed mb-4">
          {content.company_type_services} contractor serving {content.company_cover_area}.
          {content.company_years_experience}.
        </p>
        <p class="text-gray-300 text-sm mb-2">
          <strong class="text-white">Phone:</strong>
          <a href={`tel:${content.company_phone?.[0]?.replace(/[^0-9]/g, '') || ''}`} class="hover:text-accent transition-colors duration-200 ml-1">
            {content.company_phone?.[0]}
          </a>
        </p>
        <p class="text-gray-300 text-sm mb-2">
          <strong class="text-white">Email:</strong>
          <a href={`mailto:${content.company_email?.[0]}`} class="hover:text-accent transition-colors duration-200 ml-1">
            {content.company_email?.[0]}
          </a>
        </p>
        <p class="text-gray-300 text-sm">
          <strong class="text-white">Hours:</strong>
          <span class="ml-1">{content.company_schedule?.[0]}</span>
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-lg font-semibold mb-4 text-white">Our Services</h3>
        <ul class="space-y-2.5">
          {footerServices.map(service => (
            <li>
              <a
                href={`/services#${service.name.toLowerCase().replace(/\s+/g, '-')}`}
                class="text-gray-300 text-sm hover:text-accent transition-colors duration-200"
              >
                {service.name}
              </a>
            </li>
          ))}
          <li>
            <a href="/services" class="text-accent text-sm hover:underline transition-colors duration-200">
              View all services →
            </a>
          </li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-semibold mb-4 text-white">Quick Links</h3>
        <ul class="space-y-2.5">
          <li>
            <a href="/" class="text-gray-300 text-sm hover:text-accent transition-colors duration-200">Home</a>
          </li>
          <li>
            <a href="/about" class="text-gray-300 text-sm hover:text-accent transition-colors duration-200">About Us</a>
          </li>
          <li>
            <a href="/services" class="text-gray-300 text-sm hover:text-accent transition-colors duration-200">Services</a>
          </li>
          <li>
            <a href="/blog" class="text-gray-300 text-sm hover:text-accent transition-colors duration-200">Blog</a>
          </li>
          <li>
            <a href="/contact" class="text-gray-300 text-sm hover:text-accent transition-colors duration-200">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Social / Connect -->
      <div>
        <h3 class="text-lg font-semibold mb-4 text-white">Connect With Us</h3>
        <div class="flex gap-3 mb-6">
          {socialLinks.map(social => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-800 hover:bg-accent transition-colors duration-200 cursor-pointer"
              aria-label={`Follow us on ${social.label}`}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
        <p class="text-gray-300 text-sm mb-3">{content.company_estimate}</p>
        <p class="text-gray-400 text-xs">
          {content.company_license}
          {content.company_license_insurance ? ` • ${content.company_license_insurance}` : ''}
        </p>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-400 text-sm text-center md:text-left">
          © {currentYear} {content.company_name}. All rights reserved.
        </p>
        <div class="flex items-center gap-4 text-sm text-gray-400">
          <span>{content.company_payment_method}</span>
          <span class="hidden sm:inline">•</span>
          <span>Licensed & Insured</span>
        </div>
      </div>
    </div>
  </div>
</footer>