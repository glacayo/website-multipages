---
/**
 * SeoHead - Centralized SEO head component
 * Renders meta tags, OG tags, Twitter cards, canonical URL, JSON-LD scripts, and font preloading
 */
import { buildSeoMeta } from '../../data/seo';
import { generateLocalBusinessJsonLd, generateWebSiteJsonLd } from '../../utils/json-ld';
import { getSiteContent } from '../../data/loaders';

interface Props {
  title: string;
  description: string;
  path: string;
  image?: string;
  type?: 'website' | 'article';
  canonicalUrl?: string;
}

const {
  title,
  description,
  path,
  image,
  type = 'website',
  canonicalUrl,
} = Astro.props;

// Get company name from site content
const content = getSiteContent();
const companyName = content.company_name;

// Use Astro.site for canonical base, fallback to content
const siteUrl = Astro.site?.toString() || content.company_name;

// Build SEO metadata - pass explicit baseUrl for canonical generation
const seo = buildSeoMeta({
  title,
  description,
  path,
  image,
  type,
  siteName: companyName,
  baseUrl: canonicalUrl ? undefined : siteUrl,
});

// Use canonical URL if provided
const canonical = canonicalUrl || seo.canonical;

// Generate JSON-LD schemas
const localBusinessSchema = generateLocalBusinessJsonLd();
const webSiteSchema = generateWebSiteJsonLd();
---

<!-- Primary Meta Tags -->
<title>{seo.title}</title>
<meta name="title" content={seo.title} />
<meta name="description" content={seo.description} />
<link rel="canonical" href={canonical} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={seo.ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={seo.ogTitle} />
<meta property="og:description" content={seo.ogDescription} />
<meta property="og:image" content={seo.ogImage} />
<meta property="og:site_name" content={companyName} />

<!-- Twitter -->
<meta property="twitter:card" content={seo.twitterCard} />
<meta property="twitter:url" content={canonical} />
<meta property="twitter:title" content={seo.twitterTitle} />
<meta property="twitter:description" content={seo.twitterDescription} />
<meta property="twitter:image" content={seo.twitterImage} />

<!-- Fonts - Preconnect and Preload for critical fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" as="style" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={localBusinessSchema} />
<script type="application/ld+json" set:html={webSiteSchema} />