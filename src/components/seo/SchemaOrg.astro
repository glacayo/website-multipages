---
/**
 * Emit JSON-LD for Schema.org entities produced by buildSchemas().
 * Escapes raw JSON for safe embedding inside a <script> tag.
 */
import type { Thing, WithContext } from 'schema-dts';

export interface Props {
  schemas?: WithContext<Thing>[] | Record<string, unknown>[];
}

const { schemas = [] } = Astro.props;

/**
 * Serialize JSON-LD so `</script>` (and related) cannot break out of the script element.
 */
function jsonLdForScript(value: unknown): string {
  return JSON.stringify(value)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');
}

const jsonLd = schemas.length > 0 ? jsonLdForScript(schemas) : '';
---

{
  schemas.length > 0 && (
    <script is:inline type="application/ld+json" set:html={jsonLd} />
  )
}
