---
/**
 * HeroSection - Homepage hero component
 * Displays headline, subtext, CTA button, and background image
 */
import { getSiteContent } from '../../data/loaders';

interface Props {
  headline?: string;
  subtext?: string;
  buttonText?: string;
  backgroundImage?: string;
}

const content = getSiteContent();

// Props with content defaults
const headline = Astro.props.headline || content.phrases[0] || '';
const subtext = Astro.props.subtext || content.home_content[0] || '';
const buttonText = Astro.props.buttonText || 'Get Free Estimate';
const backgroundImage = Astro.props.backgroundImage || '/images/masonry-contractor.jpg';
const phoneNumber = content.company_phone?.[0] || '';
const phoneLink = `tel:${phoneNumber.replace(/[^0-9]/g, '')}`;
---

<section class="relative min-h-[600px] md:min-h-[700px] flex items-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src={backgroundImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
    />
    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-dark/80 to-dark/50"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
    <div class="max-w-4xl">
      <!-- Headline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        {headline}
      </h1>

      <!-- Subtext -->
      <p class="text-xl text-gray-200 mb-8 leading-relaxed">
        {subtext}
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 bg-accent text-white px-8 py-4 rounded-lg text-lg font-bold hover:bg-opacity-90 transition-all duration-200 cursor-pointer shadow-lg hover:shadow-xl"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          {buttonText}
        </a>

        <a
          href={phoneLink}
          class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white hover:text-primary transition-all duration-200 cursor-pointer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {phoneNumber}
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden md:block">
    <div class="animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>