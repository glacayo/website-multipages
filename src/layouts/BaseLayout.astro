---
/**
 * Site-wide layout shell:
 * SeoHead + SchemaOrg + TopBar + Header + main slot + Footer + MobileStickyBar + motion.
 */
import type { Thing, WithContext } from 'schema-dts';
import '../styles/global.css';
import SeoHead from '../components/seo/SeoHead.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import TopBar from '../components/layout/TopBar.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileStickyBar from '../components/layout/MobileStickyBar.astro';
import type { BlogPost, Service } from '../data/types';
import { getSite } from '../data/loaders';
import { buildSeo } from '../utils/seo';
import {
  buildSchemas,
  type BreadcrumbItem,
  type PageType,
} from '../utils/schema';

export interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  /** Schema page kind for buildSchemas(). Default: other. */
  pageType?: PageType;
  /** Service entity for landing pages (pageType: service). */
  service?: Service;
  /** Blog post entity for article pages (pageType: post). */
  post?: BlogPost;
  /** Optional breadcrumb trail override. */
  breadcrumbs?: BreadcrumbItem[];
  /** Force FAQPage JSON-LD (home with FAQ section). */
  includeFaq?: boolean;
  /** Full schema override; when omitted, buildSchemas() runs. */
  schema?: WithContext<Thing>[] | Record<string, unknown>[];
  /** Hide TopBar (e.g. rare full-bleed pages). */
  hideTopBar?: boolean;
  /** Hide MobileStickyBar. */
  hideMobileStickyBar?: boolean;
}

const site = getSite();

const {
  title,
  description,
  path = Astro.url.pathname,
  image,
  type,
  noindex = false,
  pageType = 'other',
  service,
  post,
  breadcrumbs,
  includeFaq,
  schema,
  hideTopBar = false,
  hideMobileStickyBar = false,
} = Astro.props;

const seo = buildSeo({
  title,
  description,
  path,
  image,
  type,
  noindex,
});

const schemas =
  schema ??
  buildSchemas({
    pageType,
    path,
    pageTitle: seo.title,
    pageDescription: seo.description,
    service,
    post,
    breadcrumbs,
    includeFaq,
  });
---

<!doctype html>
<html lang={seo.lang || site.lang || 'en'}>
  <head>
    <SeoHead seo={seo} />
    <SchemaOrg schemas={schemas} />

    <!-- Alpine.js (collapse plugin first, then core) -->
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.14.3/dist/cdn.min.js"
    ></script>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.3/dist/cdn.min.js"></script>

    <style is:global>
      [x-cloak] {
        display: none !important;
      }
    </style>
  </head>
  <body class="min-h-screen bg-surface text-dark antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-white focus:px-4 focus:py-2 focus:shadow-lg"
    >
      Skip to content
    </a>

    {!hideTopBar && <TopBar />}
    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
    {!hideMobileStickyBar && <MobileStickyBar />}

    <!-- Scroll reveal (data-reveal → .revealed); prefers-reduced-motion aware -->
    <script>
      import '../utils/motion';
    </script>
  </body>
</html>
