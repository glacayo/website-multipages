---
/**
 * BlogLayout - Layout for blog pages
 * Wraps BaseLayout with blog-specific structured data
 */
import BaseLayout from './BaseLayout.astro';
import { generateBlogPostingJsonLd } from '../utils/json-ld';
import type { BlogPost } from '../data/types';

interface Props {
  title: string;
  description: string;
  path: string;
  image?: string;
  post?: BlogPost;
}

const {
  title,
  description,
  path,
  image,
  post,
} = Astro.props;

// Generate BlogPosting JSON-LD if post data is provided
const blogPostingSchema = post ? generateBlogPostingJsonLd(post) : null;
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  image={image}
  type="article"
>
  <slot />

  {/* BlogPosting JSON-LD */}
  {blogPostingSchema && (
    <script type="application/ld+json" set:html={blogPostingSchema} />
  )}
</BaseLayout>
