---
/**
 * Service landing layout: hero + breadcrumb + content sections + shared trust blocks.
 * Merges landings.json (when present) with services.json; falls back to service + business.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import Button from '../components/ui/Button.astro';
import ResponsiveImage from '../components/ui/ResponsiveImage.astro';
import SectionWrapper from '../components/ui/SectionWrapper.astro';
import CTABar from '../components/sections/CTABar.astro';
import Testimonials from '../components/sections/Testimonials/Testimonials.astro';
import Gallery from '../components/sections/Gallery/Gallery.astro';
import CoveredAreas from '../components/sections/CoveredAreas/CoveredAreas.astro';
import DirectoryBadges from '../components/sections/DirectoryBadges/DirectoryBadges.astro';
import type { LandingPage, LandingSection, Service } from '../data/types';
import {
  getBusiness,
  getContactPath,
  getLandingPage,
  getService,
  getSite,
} from '../data/loaders';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const business = getBusiness();
const site = getSite();
const contactHref = getContactPath();
const service = getService(slug);
const landing = getLandingPage(slug);

if (!service && !landing) {
  return Astro.redirect('/services');
}

const serviceForSchema: Service =
  service ??
  ({
    id: landing?.service_id || slug,
    name: landing?.name || slug,
    slug,
    short_description: landing?.hero.paragraph.slice(0, 160) || '',
    full_description: landing?.hero.paragraph || '',
    image: landing?.hero.image || site.seo.default_image,
  } satisfies Service);

/** Resolved landing view model (custom landing or generic fallback). */
const page: LandingPage =
  landing ??
  ({
    name: serviceForSchema.name,
    slug,
    service_id: serviceForSchema.id,
    meta_title: `${serviceForSchema.name}${site.seo.title_separator}${business.name}`,
    meta_description:
      serviceForSchema.short_description ||
      `${serviceForSchema.name} services from ${business.name} in ${business.service_area}.`,
    hero: {
      headline: serviceForSchema.name,
      paragraph: serviceForSchema.full_description || serviceForSchema.short_description,
      image: serviceForSchema.image,
      image_alt: `${serviceForSchema.name} project by ${business.name}`,
    },
    sections: [
      {
        headline: `Why choose ${business.name} for ${serviceForSchema.name}?`,
        paragraphs: [
          serviceForSchema.full_description || serviceForSchema.short_description,
          `Licensed and insured. ${business.free_estimate}. Serving ${business.service_area}.`,
        ],
        image: serviceForSchema.image,
        image_alt: `${serviceForSchema.name} craftsmanship`,
      },
    ] satisfies LandingSection[],
    cta: {
      headline: `Ready for a free ${serviceForSchema.name.toLowerCase()} estimate?`,
      button_label: 'Contact Us',
    },
  } satisfies LandingPage);

const title =
  page.meta_title ||
  `${page.name}${site.seo.title_separator}${business.name}`;
const description =
  page.meta_description ||
  page.hero.paragraph.slice(0, 160);
const primaryPhone = business.phones[0] ?? '';
const phoneHref = `tel:${primaryPhone.replace(/\D/g, '')}`;
const highlights = service?.highlights ?? [];

const uiBreadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: page.name },
];

const schemaBreadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Services', path: '/services' },
  { name: page.name, path: `/services/${slug}` },
];
---

<BaseLayout
  title={title}
  description={description}
  path={`/services/${slug}`}
  pageType="service"
  service={serviceForSchema}
  breadcrumbs={schemaBreadcrumbs}
  image={page.hero.image}
>
  <!-- Hero -->
  <section class="relative">
    <div class="relative min-h-[520px] md:min-h-[600px] overflow-hidden bg-dark">
      <div class="absolute inset-0">
        <ResponsiveImage
          src={page.hero.image}
          alt={page.hero.image_alt || page.name}
          width={1920}
          height={1080}
          lcp
          class="h-full w-full object-cover"
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-dark/90 via-primary/50 to-accent/50"></div>

      <div class="relative z-10 container-site flex min-h-[520px] md:min-h-[600px] items-center py-24 md:py-32">
        <div class="max-w-2xl text-white">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-accent">
            {business.type_of_services}
          </p>
          <h1 class="font-heading mb-4 text-3xl font-bold leading-tight md:text-5xl">
            {page.hero.headline}
          </h1>
          <p class="mb-8 text-base leading-relaxed text-white/85 md:text-lg">
            {page.hero.paragraph}
          </p>
          <div class="flex flex-col items-start gap-3 sm:flex-row">
            <Button href={contactHref} variant="primary" size="md">
              {page.cta.button_label}
            </Button>
            {
              primaryPhone && (
                <Button href={phoneHref} variant="outline" size="md" class="border-white/40 text-white hover:bg-white hover:text-primary">
                  {primaryPhone}
                </Button>
              )
            }
          </div>
        </div>
      </div>
    </div>

    <div class="border-b border-white/10 bg-dark/90">
      <div class="container-site py-3">
        <Breadcrumb
          items={uiBreadcrumbs}
          class="[&_a]:text-white/70 [&_a:hover]:text-accent [&_span]:text-white/90 [&_.text-muted]:text-white/50 [&_.text-dark]:text-white"
        />
      </div>
    </div>
  </section>

  <!-- Landing content sections -->
  {
    page.sections.map((section, index) => {
      const reverse = index % 2 === 1;
      return (
        <SectionWrapper background={reverse ? 'dark' : 'default'} class="!py-16 md:!py-24">
          <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
            <div class:list={[reverse && 'lg:order-2']}>
              <h2
                class:list={[
                  'font-heading mb-6 text-2xl font-bold md:text-3xl',
                  reverse ? 'text-light' : 'text-dark',
                ]}
              >
                {section.headline}
              </h2>
              <div
                class:list={[
                  'space-y-4 text-sm leading-relaxed md:text-base',
                  reverse ? 'text-light/75' : 'text-muted',
                ]}
              >
                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
              {
                index === 0 && highlights.length > 0 && (
                  <ul class="mt-6 grid grid-cols-1 gap-2 sm:grid-cols-2">
                    {highlights.map((item) => (
                      <li
                        class:list={[
                          'flex items-center gap-2 text-sm font-medium',
                          reverse ? 'text-light' : 'text-dark',
                        ]}
                      >
                        <span class="text-accent" aria-hidden="true">
                          ✓
                        </span>
                        {item}
                      </li>
                    ))}
                  </ul>
                )
              }
            </div>
            <div class:list={['overflow-hidden rounded-2xl shadow-lg', reverse && 'lg:order-1']}>
              <ResponsiveImage
                src={section.image}
                alt={section.image_alt || section.headline}
                width={900}
                height={600}
                class="h-[320px] w-full object-cover md:h-[400px]"
              />
            </div>
          </div>
        </SectionWrapper>
      );
    })
  }

  <!-- Service-level FAQ when present -->
  {
    service?.faq && service.faq.length > 0 && (
      <SectionWrapper background="muted" class="!py-16 md:!py-24">
        <h2 class="font-heading mb-8 text-center text-2xl font-bold text-dark md:text-3xl">
          {page.name} FAQ
        </h2>
        <div class="mx-auto max-w-3xl space-y-4">
          {service.faq.map((item) => (
            <details class="rounded-xl border border-border bg-white p-5">
              <summary class="cursor-pointer font-semibold text-dark">{item.q}</summary>
              <p class="mt-3 text-sm leading-relaxed text-muted">{item.a}</p>
            </details>
          ))}
        </div>
      </SectionWrapper>
    )
  }

  <!-- Mid-page CTA -->
  <section class="bg-primary py-12 md:py-16">
    <div class="container-site flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
      <h2 class="font-heading max-w-2xl text-2xl font-bold text-white md:text-3xl">
        {page.cta.headline}
      </h2>
      <Button href={contactHref} variant="primary" size="lg">
        {page.cta.button_label}
      </Button>
    </div>
  </section>

  {site.features.enable_testimonials && <Testimonials />}
  {site.features.enable_gallery && <Gallery />}
  {site.features.enable_areas && <CoveredAreas />}
  {site.features.enable_directories && <DirectoryBadges />}
  <CTABar />
</BaseLayout>
