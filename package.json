{
  "name": "website-contractor-multipages",
  "version": "1.0.0",
  "description": "Multipage contractor website template with placeholder content",
  "type": "module",
  "scripts": {
    "guard:pm": "node ./scripts/enforce-package-manager.cjs",
    "preinstall": "node ./scripts/enforce-package-manager.cjs",
    "dev": "node ./scripts/enforce-package-manager.cjs && astro dev",
    "start": "node ./scripts/enforce-package-manager.cjs && astro dev",
    "build": "node ./scripts/enforce-package-manager.cjs && astro build",
    "preview": "node ./scripts/enforce-package-manager.cjs && astro preview",
    "astro": "node ./scripts/enforce-package-manager.cjs && astro",
    "ci:install": "pnpm install --frozen-lockfile",
    "deps:outdated": "pnpm outdated"
  },
  "keywords": [
    "astro",
    "contractor",
    "masonry",
    "hardscape"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "alpinejs": "^3.15.12",
    "astro": "^6.3.1",
    "gsap": "^3.15.0",
    "swiper": "^12.1.4",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "sharp": "^0.34.5"
  },
  "engines": {
    "pnpm": ">=11.1.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.1.2",
      "onFail": "error"
    }
  }
}
