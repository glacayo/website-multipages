{
  "name": "website-contractor-multipages",
  "version": "2.1.0",
  "description": "Multipage contractor website template with placeholder content",
  "type": "module",
  "scripts": {
    "guard:pm": "node ./scripts/enforce-package-manager.cjs",
    "preinstall": "node ./scripts/enforce-package-manager.cjs",
    "dev": "node ./scripts/enforce-package-manager.cjs && astro dev",
    "start": "node ./scripts/enforce-package-manager.cjs && astro dev",
    "build": "node ./scripts/enforce-package-manager.cjs && node ./scripts/validate-data.cjs && astro check && astro build",
    "preview": "node ./scripts/enforce-package-manager.cjs && astro preview",
    "astro": "node ./scripts/enforce-package-manager.cjs && astro",
    "ci:install": "pnpm install --frozen-lockfile",
    "deps:outdated": "pnpm outdated",
    "validate:data": "node ./scripts/enforce-package-manager.cjs && node ./scripts/validate-data.cjs",
    "test:cli": "node ./packages/create-contractor-site/scripts/smoke-test.mjs"
  },
  "keywords": [
    "astro",
    "contractor",
    "masonry",
    "hardscape"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@lucide/astro": "^1.24.0",
    "@tailwindcss/vite": "^4.3.2",
    "alpinejs": "^3.15.12",
    "astro": "^7.0.9",
    "swiper": "^12.1.4",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/alpinejs": "^3.13.11",
    "schema-dts": "^1.1.5",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "zod": "^4.1.5"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.1.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.1.2",
      "onFail": "error"
    }
  }
}
