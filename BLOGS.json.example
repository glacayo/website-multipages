{
    "_instructions": {
        "_readme": "Blog posts for contractor/home-service websites. Fill CLIENT DATA fields manually. Leave AI COPY fields as [PLACEHOLDER] — the agent writes them based on your client data.",
        "_client_data": "Fill these manually: author, category, date (optional)",
        "_ai_copy": "Leave these as [PLACEHOLDER] — the agent writes them",
        "headline": "1 h1 headline, max 14 words, SEO-optimized",
        "content": "Full blog body with HTML markup (<p>, <h2>, <h3>, <ul>, <li>, <strong>, etc.), min 600 words, max 1500 words",
        "excerpt": "1-2 sentences summary, max 30 words",
        "description": "Meta description, max 160 characters",
        "meta_title": "SEO title, max 60 characters",
        "images": "Just the filename with extension, no path",
        "reading_time": "Calculated from content (~200 words/min)"
    },

    "__CLIENT_DATA__": "─── Fill these fields ───",

    "default_author": "[e.g. Company Name]",
    "default_category": "[e.g. Masonry, Hardscape, Concrete]",

    "__AI_COPY__": "─── Leave these as [PLACEHOLDER] — the agent writes them ───",

    "posts": [
        {
            "headline": "[PLACEHOLDER]",
            "slug": "[PLACEHOLDER — auto-generated from headline]",
            "content": "[PLACEHOLDER — full blog HTML body]",
            "image_filename": "[PLACEHOLDER — e.g. blog-post-name.jpg]",
            "date": "[PLACEHOLDER — e.g. 2025-01-01]",
            "author": "[uses default_author or override here]",
            "category": "[uses default_category or override here]",
            "reading_time": "[PLACEHOLDER — e.g. 5 min]",
            "excerpt": "[PLACEHOLDER]",
            "description": "[PLACEHOLDER — meta description]",
            "meta_title": "[PLACEHOLDER — SEO title]"
        }
    ]
}
